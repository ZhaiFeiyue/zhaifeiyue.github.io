<mxfile host="app.diagrams.net" modified="2026-04-20" agent="paper-reader" version="24.0.0" pages="2">
  <diagram id="page1" name="PASTE System Architecture">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <!-- Title -->
        <mxCell id="title" value="PASTE: Pattern-Aware Speculative Tool Execution" style="text;html=1;fontSize=18;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="600" height="30" as="geometry"/>
        </mxCell>
        <!-- Agent Layer -->
        <mxCell id="agent-box" value="Agent (LLM)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="50" width="400" height="50" as="geometry"/>
        </mxCell>
        <!-- PASTE Middleware Layer -->
        <mxCell id="paste-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3CD;strokeColor=#E0A800;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="130" width="1000" height="400" as="geometry"/>
        </mxCell>
        <mxCell id="paste-label" value="PASTE Middleware (~12K LOC)" style="text;html=1;fontSize=16;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="400" y="135" width="400" height="25" as="geometry"/>
        </mxCell>
        <!-- Event Extractor -->
        <mxCell id="event-ext" value="Event Extractor&#xa;(Normalize tool invocation logs&#xa;into event signatures)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFD6D6;strokeColor=#CC0000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="150" y="180" width="200" height="70" as="geometry"/>
        </mxCell>
        <!-- Pattern Miner (Offline) -->
        <mxCell id="pattern-miner" value="Pattern Miner (Offline)&#xa;Algorithm 1: PrefixSpan&#xa;mine frequent subsequences&#xa;+ symbolic dependency inference" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="750" y="180" width="300" height="80" as="geometry"/>
        </mxCell>
        <!-- Pattern Pool -->
        <mxCell id="pattern-pool" value="Pattern Pool P&#xa;{(C, T, f, p)}&#xa;e.g. P1: [(Search,ok)] → Web_fetch, p=0.9&#xa;e.g. P2: [(Search,ok),(Fetch,fail)] → Web_fetch, p=0.8" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="750" y="290" width="300" height="80" as="geometry"/>
        </mxCell>
        <!-- Predictor -->
        <mxCell id="predictor" value="Online Predictor&#xa;Algorithm 2: Context Matching&#xa;(hash-map lookup, O(1) per key)&#xa;+ Function Evaluation (late-binding)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="200" width="280" height="70" as="geometry"/>
        </mxCell>
        <!-- Speculative Scheduler -->
        <mxCell id="scheduler" value="Speculative Scheduler&#xa;Algorithm 3: 4-step scheduling&#xa;1. Confirm matching spec jobs&#xa;2. Preempt spec for auth resources&#xa;3. Schedule authoritative jobs&#xa;4. Opportunistic spec scheduling&#xa;U(j) = p·T / (c·d)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="250" y="310" width="280" height="110" as="geometry"/>
        </mxCell>
        <!-- Speculation Eligibility Policy -->
        <mxCell id="policy" value="Eligibility Policy&#xa;- Side-effect constraints&#xa;- Graded speculation&#xa;  (full / dry_run / warm-up)&#xa;- Dedup: max expected utility" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#B3E5FC;strokeColor=#0277BD;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="570" y="310" width="150" height="100" as="geometry"/>
        </mxCell>
        <!-- Speculative Invocation Arbiter -->
        <mxCell id="arbiter" value="Invocation Arbiter&#xa;Authoritative vs Speculative&#xa;Promotion Protocol:&#xa;spec→auth on match" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D7CCC8;strokeColor=#5D4037;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="150" y="310" width="160" height="80" as="geometry"/>
        </mxCell>
        <!-- Tool System Layer -->
        <mxCell id="tool-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;strokeWidth=2;" vertex="1" parent="1">
          <mxGeometry x="100" y="560" width="1000" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="tool-label" value="Tool System" style="text;html=1;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="530" y="565" width="140" height="20" as="geometry"/>
        </mxCell>
        <mxCell id="auth-tools" value="Agent Tool Procs&#xa;(Authoritative)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="200" y="590" width="160" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="spec-tools" value="Spec Tool Procs&#xa;(Best-effort, preemptible)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#A5D6A7;strokeColor=#2E7D32;fontSize=11;strokeDasharray=8 4;" vertex="1" parent="1">
          <mxGeometry x="750" y="590" width="200" height="40" as="geometry"/>
        </mxCell>
        <!-- Arrows -->
        <mxCell id="a1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#0D47A1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="agent-box" target="event-ext">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a1-label" value="Agent Tool Calls" style="edgeLabel;html=1;fontSize=10;fontColor=#0D47A1;" vertex="1" connectable="0" parent="a1">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="a2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;endArrow=block;" edge="1" parent="1" source="event-ext" target="predictor">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;endArrow=block;" edge="1" parent="1" source="event-ext" target="pattern-miner">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;endArrow=block;" edge="1" parent="1" source="pattern-miner" target="pattern-pool">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;endArrow=block;" edge="1" parent="1" source="pattern-pool" target="predictor">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;endArrow=block;" edge="1" parent="1" source="predictor" target="scheduler">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a6-label" value="Predictive Hints&#xa;{(e_pred, p)}" style="edgeLabel;html=1;fontSize=9;" vertex="1" connectable="0" parent="a6">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="a7" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#333;strokeWidth=1.5;endArrow=block;" edge="1" parent="1" source="scheduler" target="arbiter">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a8" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#0D47A1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="arbiter" target="auth-tools">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#E65100;strokeWidth=1.5;endArrow=block;strokeDasharray=8 4;" edge="1" parent="1" source="scheduler" target="spec-tools">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="a9-label" value="Speculative Calls&#xa;(preemptible)" style="edgeLabel;html=1;fontSize=9;fontColor=#E65100;" vertex="1" connectable="0" parent="a9">
