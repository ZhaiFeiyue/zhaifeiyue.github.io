  <diagram id="page2" name="Pattern Tuple Abstraction">
    <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title2" value="Pattern Tuple: (C, T, f, p)" style="text;html=1;fontSize=18;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="300" y="10" width="500" height="30" as="geometry"/>
        </mxCell>
        <!-- Context C -->
        <mxCell id="c-box" value="C = Context (Control Flow Anchor)&#xa;Order-preserving subsequence of event signatures&#xa;Payload-agnostic: only (tool_type, status)&#xa;Example: [(Search, success)]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="60" width="350" height="90" as="geometry"/>
        </mxCell>
        <!-- Target T -->
        <mxCell id="t-box" value="T = Target (Prediction)&#xa;Predicted future tool type&#xa;Example: Web_fetch" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#C8E6C9;strokeColor=#2E7D32;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="60" width="250" height="70" as="geometry"/>
        </mxCell>
        <!-- Function f -->
        <mxCell id="f-box" value="f = Value Mapping Function (Data Flow)&#xa;Symbolic function: derive args from C payloads&#xa;Late-binding resolution at runtime&#xa;Example: arg0 = SearchRes[&quot;list&quot;][0][&quot;url&quot;]&#xa;Types: field/path lookup, index+fallback, string fmt" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="50" y="180" width="400" height="100" as="geometry"/>
        </mxCell>
        <!-- Probability p -->
        <mxCell id="p-box" value="p = Probability (Confidence)&#xa;Empirical success rate from validation&#xa;Validated: p = |M*| / |C_matches|&#xa;Threshold: discard if p &lt; τ&#xa;Used for priority: U(j) = p·T / (c·d)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="180" width="300" height="100" as="geometry"/>
        </mxCell>
        <!-- Two-Phase Mining -->
        <mxCell id="mining-title" value="Two-Phase Mining Strategy (Algorithm 1)" style="text;html=1;fontSize=14;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="320" width="500" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="phase1-mine" value="Phase I: Structural Mining&#xa;PrefixSpan on event signatures&#xa;→ Candidate (C, T) pairs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE0B2;strokeColor=#E65100;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="360" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="phase2-mine" value="Phase II: Symbolic Dependency Inference&#xa;InferValueMapping on matched occurrences&#xa;→ Value mapping function f" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#BBDEFB;strokeColor=#1565C0;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="360" width="280" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="validation" value="Validation&#xa;p = |M*| / |C| ≥ τ" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1BEE7;strokeColor=#7B1FA2;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="770" y="360" width="150" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="ma1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="phase1-mine" target="phase2-mine">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="ma2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeWidth=2;endArrow=block;" edge="1" parent="1" source="phase2-mine" target="validation">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <!-- Example patterns -->
        <mxCell id="ex-title" value="Example Patterns from Agent Traces" style="text;html=1;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="250" y="470" width="500" height="25" as="geometry"/>
        </mxCell>
        <mxCell id="ex1" value="Deep Research:&#xa;Search → Web_fetch (p=0.9)&#xa;55% edit→test, 51% search→visit" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="250" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ex2" value="Coding:&#xa;file_editor → pytest (55%)&#xa;grep → file_editor (38%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="400" y="510" width="220" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="ex3" value="Data Flow:&#xa;95% URLs from search results&#xa;Producer→Consumer pattern" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF9C4;strokeColor=#F9A825;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="670" y="510" width="220" height="70" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
