        <mxCell id="random" value="Pool of 128-tok&#10;random segments [rⱼ]&#10;from C" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="640" y="320" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rejectS" value="Reject sampling&#10;⇒ length(L) uniform&#10;over [4K, 32K]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="880" y="320" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="shuffle" value="Shuffle &amp; concat&#10;Lᵢ = ⊕Shuffle({sᵢ⋯} ∪ {rⱼ})" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="1100" y="320" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="dataset" value="IN2 Dataset D = {(Lᵢ, qᵢ, aᵢ)}&#10;1.1M fine-grained (63%) + 0.3M multi-hop (17%)&#10;+ 0.15M short QA (9%) + 0.20M OpenOrca (11%)&#10;= 1.75M examples total" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="450" width="380" height="80" as="geometry" />
        </mxCell>
        <mxCell id="backbone" value="Mistral-7B-Instruct-v0.2&#10;(no sliding window;&#10;RoPE base θ = 1e6 default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="1">
          <mxGeometry x="60" y="600" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="train" value="Instruction-tuning loss on aᵢ only&#10;Template: [INST] Context Lᵢ Instruction qᵢ [/INST] aᵢ&#10;global BS=128, 1 epoch, ~14K steps&#10;cosine LR, max 1e-6, 3% warmup&#10;FSDP full-shard + CPU offload&#10;16 nodes × 8×80GB A100 (~300 GPU-days)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="320" y="580" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="film" value="FilM-7B (FILl-in-the-Middle)&#10;32K context, retains short-ctx perf,&#10;robust mid-context retrieval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="600" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="eval" value="Evaluation:&#10;• VaL Probing (doc / code / database; fwd / bwd / bi-dir)&#10;• 9 LongBench tasks (NarrativeQA, Qasper, …)&#10;• 8 short-ctx tasks (MMLU, BoolQ, …)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;align=left;spacingLeft=10;" vertex="1" parent="1">
