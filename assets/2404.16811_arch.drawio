  <diagram name="VaL-Probing" id="page2">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="VaL Probing — 3 Context Styles × 3 Retrieval Patterns" style="text;html=1;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="header1" value="Context Style →" style="text;html=1;align=center;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="h1" value="Document (NL sentences from arXiv abstracts)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="280" y="100" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="Code (Python functions from StarCoder)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="640" y="100" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="Database (Wikidata entities: ID, label, desc)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1000" y="100" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="Retrieval Pattern" style="text;html=1;align=center;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="200" width="160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="d1" value="Bi-directional&#10;(query is a SNIPPET inside the sentence; need words&#10;both before AND after the snippet)&#10;Metric: word-level recall" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="180" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="d2" value="Backward&#10;(query is a line INSIDE function body; need&#10;function name which appears BEFORE the line)&#10;Metric: exact-match accuracy" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="640" y="180" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="d3" value="Forward&#10;(query is the ID; need label+description which&#10;follow it)&#10;Metric: relaxed exact-match (label OR desc)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="180" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="ctx1" value="Context: ~32K tokens (~800 sentences)&#10;Examples per task: ~3K&#10;Position bins: every 50 sentences" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="280" y="340" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ctx2" value="Context: ~32K tokens (~800 functions)&#10;Examples per task: ~3K&#10;Position bins: every 50 functions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="640" y="340" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="ctx3" value="Context: ~32K tokens (~750 entities)&#10;Examples per task: ~3K&#10;Position bins: every 50 entities" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="1000" y="340" width="320" height="80" as="geometry" />
        </mxCell>
        <mxCell id="comp" value="Comparison vs Needle-in-the-Haystack" style="text;html=1;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="200" y="460" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="nih" value="Needle-in-the-Haystack&#10;• Style: document (NL — familiar to LLMs)&#10;• Pattern: forward (induction-head copy is easy)&#10;• Example: best thing to do in SF → ‘eat a sandwich…’&#10;• Result: most 32K models score ~100%&#10;⇒ overestimates real long-context capability" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="500" width="500" height="160" as="geometry" />
        </mxCell>
        <mxCell id="val" value="VaL Probing&#10;• 3 styles × 3 patterns; structured + code added&#10;• Backward / bi-directional break induction-head shortcut&#10;• Two metrics: Avg (utilization) and Gap (robustness)&#10;⇒ Mistral-v0.2/LongAlign/InternLM2 all show U-shape&#10;⇒ FilM-7B alone is flat across positions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="820" y="500" width="500" height="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Failure-Modes" id="page3">
    <mxGraphModel dx="1422" dy="757" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Why Lost-in-the-Middle Happens — Position Bias from Training Data" style="text;html=1;align=center;fontSize=20;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1200" height="40" as="geometry" />
        </mxCell>
        <mxCell id="cause1" value="Cause #1 — Pretraining bias (auto-regressive)&#10;Next-token loss is dominated by NEAR pre-tokens.&#10;⇒ long-distance attention is under-trained" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cause2" value="Cause #2 — SFT/alignment bias&#10;System message at the BEGINNING strongly steers&#10;the response. Important info repeatedly co-occurs&#10;at position 0.&#10;⇒ model learns ‘information lives at the edges’" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="100" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="cause3" value="Cause #3 — Long-context SFT data scarcity&#10;Standard long-ctx SFT places gold answer near&#10;the start or end (chat / RAG style).&#10;⇒ middle positions never get gradient" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="100" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="lim" value="Lost-in-the-Middle ‘U-shape’ accuracy curve" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="500" y="280" width="380" height="50" as="geometry" />
        </mxCell>
        <mxCell id="fix" value="IN2 fix: every 128-tok segment can hold the answer.&#10;Reject-sample to ensure UNIFORM gold-segment position&#10;over [0, L]. Loss is computed only on the answer aᵢ,&#10;so the gradient only rewards correctly attending to the&#10;gold middle segment, not parroting nearby tokens." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d4edda;strokeColor=#28a745;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="400" y="380" width="580" height="120" as="geometry" />
        </mxCell>
        <mxCell id="key" value="Key design constraints (why other approaches fail)" style="text;html=1;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="100" y="540" width="1200" height="30" as="geometry" />
        </mxCell>
        <mxCell id="alt1" value="Alt A: Sliding-window attention (Mistral-v0.1 4K SW)&#10;Why fails: distance &gt; window ⇒ 0 signal.&#10;Fig. 6 shows accuracy collapses past 4K. NOT a fix." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="60" y="590" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="alt2" value="Alt B: Just extend context (RoPE θ↑) without IN2 data&#10;Why fails: model can ATTEND to far tokens but still&#10;has the position-bias prior. FilM ablation shows IN2&#10;DATA matters more than θ alone, but θ=10× helps too." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="500" y="590" width="380" height="100" as="geometry" />
        </mxCell>
        <mxCell id="alt3" value="Alt C: Train on real long-doc QA (e.g. NarrativeQA)&#10;Why fails: gold answer position is non-uniform AND&#10;data scale is small (~1k examples). IN2 synthesizes&#10;1.4M examples with FORCED uniform position.&#10;⇒ data-driven solution, no architecture change needed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;align=left;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="940" y="590" width="380" height="120" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="cause1" target="lim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="cause2" target="lim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="cause3" target="lim">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;" edge="1" parent="1" source="lim" target="fix">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
