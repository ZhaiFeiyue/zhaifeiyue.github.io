  <diagram name="single-vs-multihop" id="page1">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t1" value="Single-hop QA  (prior &quot;Lost in the Middle&quot; setup)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="t2" value="Multi-hop QA  (this paper)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="20" width="560" height="30" as="geometry" />
        </mxCell>
        <mxCell id="sh_q" value="Question:&#xa;&quot;What year was X founded?&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="mh_q" value="Question:&#xa;&quot;In what year was the founder of X born?&quot;&#xa;(needs 2+ hops: founder of X → year of birth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="620" y="60" width="320" height="60" as="geometry" />
        </mxCell>
        <mxCell id="sh_label" value="20 retrieved documents (1 gold)" style="text;html=1;align=center;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="120" width="560" height="20" as="geometry" />
        </mxCell>
        <mxCell id="mh_label" value="20 retrieved documents (k gold, k=2..4)" style="text;html=1;align=center;fontSize=11;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="620" y="120" width="560" height="20" as="geometry" />
        </mxCell>
        <mxCell id="sh_d1" value="Doc 1 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="150" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_d2" value="Doc 2 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="170" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_d3" value="Doc 3 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="190" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_d4" value="Doc 4 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="210" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_gold" value="Doc 5  ★  GOLD (contains answer)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="20" y="230" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_d6" value="Doc 6 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="250" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_dot" value="...  (positions 7-19 = distractors)" style="text;html=1;align=center;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="20" y="270" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_d20" value="Doc 20 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="20" y="290" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="sh_axis" value="Vary the 1 gold doc&#39;s position (1 → 20)  ⇒  classic U-shape accuracy curve" style="text;html=1;align=center;fontSize=12;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="20" y="320" width="560" height="30" as="geometry" /></mxCell>
        <mxCell id="mh_d1" value="Doc 1 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="150" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_d2" value="Doc 2 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="170" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_g1" value="Doc 3  ★  GOLD #1  (founder = Y)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="620" y="190" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_d4" value="Doc 4 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="210" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_d5" value="Doc 5 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="230" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_d6" value="Doc 6 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="250" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_d7" value="Doc 7 (distractor)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="620" y="270" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_g2" value="Doc 8  ★  GOLD #2  (Y was born in 1923)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="620" y="290" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_dot" value="...  (positions 9-20 = distractors)" style="text;html=1;align=center;fontSize=11;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="620" y="310" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_arrow" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;strokeColor=#b85450;strokeWidth=2;dashed=1;" edge="1" parent="1" source="mh_g1" target="mh_g2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="mh_dist" value="distance d = 5 (gold #1 at pos 3, gold #2 at pos 8)" style="text;html=1;align=center;fontSize=11;fontColor=#b85450;fontStyle=2;" vertex="1" parent="1"><mxGeometry x="940" y="240" width="240" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_ax1" value="NEW dimension 1: vary k gold positions  (1,2) (5,6) (10,11) (15,16) (19,20) — &quot;adjacent&quot;" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="620" y="340" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="mh_ax2" value="NEW dimension 2: vary distance d  (1,5) (5,10) (10,15) (15,20) — &quot;separated&quot;" style="text;html=1;align=center;fontSize=11;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1"><mxGeometry x="620" y="362" width="560" height="20" as="geometry" /></mxCell>
        <mxCell id="finding" value="Key finding:  performance drops not just with distance from edges (lost-in-middle),&#xa;but ALSO with distance BETWEEN gold docs (lost-in-between)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="20" y="420" width="1160" height="60" as="geometry" />
        </mxCell>
        <mxCell id="explode" value="Why prior mitigations break:&#xa;• Re-ranking: requires C(20,k) permutations, k=4 ⇒ 4845 orderings per question.&#xa;• Long-context fine-tuning: must teach all positional combos — combinatorial explosion.&#xa;• Summarization: every reduction step risks dropping a critical hop, breaking the chain." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="500" width="1160" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="experimental-pipeline" id="page2">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Experimental Pipeline:  context reduction × CoT × position sweep" style="text;html=1;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="ds" value="3 MHQA datasets&#xa;• HotpotQA (2-hop, 3703 Q)&#xa;• 2WikiMultihopQA (2/4-hop, 6288 Q)&#xa;• MuSiQue-Ans (2/3/4-hop, 1209 Q)&#xa;&#xa;k = 2/3/4 gold docs" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="reduce" value="Document representation (3 modes)&#xa;━━━━━━━━━━━━━━━━━━&#xa;1. Full Doc&#xa;   • HotpotQA: avg 69 words&#xa;   • 2Wiki: 45 words&#xa;   • MuSiQue: 85 words&#xa;2. Summary  (BART-large-CNN, ≤50 tok)&#xa;   • Hotpot: 29 / 2Wiki: 21 / MuSiQue: 32&#xa;3. KG Triples  (LLaMA-2-7B prompted)&#xa;   • Hotpot: 33 / 2Wiki: 29 / MuSiQue: 35" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="270" y="60" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="pos" value="Position generator&#xa;━━━━━━━━━━━━━━━&#xa;Total positions n = 20.&#xa;k gold = 2..4.&#xa;Naïve: C(20,k) up to 4845.&#xa;Subsample to 9 settings:&#xa;  • 5 ADJACENT&#xa;     (1,2) (5,6) (10,11) (15,16) (19,20)&#xa;  • 4 SEPARATED&#xa;     (1,5) (5,10) (10,15) (15,20)&#xa;Distractors keep retrieval order." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="580" y="60" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="prompt" value="Prompt mode (× 2)&#xa;━━━━━━━━━━━━━&#xa;A. Standard zero-shot&#xa;B. Few-shot CoT (Least-to-Most)&#xa;&#xa;Models (3):&#xa;• MPT-7B-8k-instruct (ALiBi)&#xa;• Llama-2-7B-longlora-8k-ft&#xa;• GPT-3.5-turbo-1106 (16k ctx)&#xa;&#xa;temperature = 0, max_new = 256" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="890" y="60" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="metric" value="Metric&#xa;best-subspan accuracy&#xa;(answer is substring of output)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="1200" y="60" width="180" height="120" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="ds" target="reduce"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="reduce" target="pos"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="pos" target="prompt"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;" edge="1" parent="1" source="prompt" target="metric"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="grid" value="Total grid:  3 datasets × {2,3,4} hops × 9 positions × 3 reductions × 2 prompts × 3 models" style="text;html=1;align=center;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="1360" height="30" as="geometry" />
        </mxCell>
        <mxCell id="r1" value="Result 1  (Fig 4)&#xa;Adjacent &gt; Separated  on every (model, dataset) pair.&#xa;e.g. GPT-3.5 MuSiQue 2-hop: adj 49.4 → sep 45.2 (-4 pp).&#xa;        MPT MuSiQue 2-hop: adj 26.7 → sep 23.8 (-3 pp).&#xa;⇒ &quot;lost in BETWEEN&quot; — distance between golds matters." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="330" width="430" height="120" as="geometry" />
        </mxCell>
        <mxCell id="r2" value="Result 2  (Fig 2,3)&#xa;CoT helps instruction-tuned (MPT, GPT) but does NOT&#xa;flatten the U-curve.&#xa;CoT CRASHES Llama-2-longlora (e.g. Hotpot 51.9 → 0.6)&#xa;— primacy bias overweights few-shot exemplars." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="475" y="330" width="430" height="120" as="geometry" />
        </mxCell>
        <mxCell id="r3" value="Result 3  (Fig 2)&#xa;Reduction (KG, Summary) flattens the position curve&#xa;but absolute accuracy drops sharply&#xa;(GPT Hotpot full 73.9 → KG 54.3 → Summary 59.5).&#xa;Useful for weak models (Llama-longlora benefits)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="930" y="330" width="450" height="120" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="position-curve-mental-model" id="page3">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Two stacked biases the paper isolates" style="text;html=1;align=center;fontSize=16;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1160" height="30" as="geometry" />
        </mxCell>
        <mxCell id="b1" value="Bias 1 — Lost in the Middle  (Liu et al. 2024)&#xa;Single piece of evidence.  Accuracy is U-shaped wrt&#xa;the absolute position of that evidence.&#xa;HIGH at both ends, LOW in the middle." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="60" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="b2" value="Bias 2 — Lost In-Between  (this paper)&#xa;k pieces of evidence (k≥2).  Beyond the U-shape,&#xa;accuracy ALSO drops monotonically with the distance&#xa;|pos_i − pos_j| between the gold pieces." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="620" y="60" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ax1" value="absolute position of gold doc:&#xa;  1 ─ 5 ─ 10 ─ 15 ─ 20&#xa;accuracy(pos):&#xa;  HIGH ─ low ─ LOWEST ─ low ─ HIGH" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#6c8ebf;fontSize=12;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="20" y="180" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="ax2" value="(adj)   d=1     d=4     d=5     d=10&#xa;(1,2) (1,5)  (5,10)  (10,15)&#xa;accuracy:&#xa;  HIGH &gt; med &gt; lower &gt; LOWEST&#xa;(monotone decay in d, conditioning on same midpoint)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#b85450;fontSize=12;align=left;fontFamily=Courier New;" vertex="1" parent="1">
          <mxGeometry x="620" y="180" width="560" height="100" as="geometry" />
        </mxCell>
        <mxCell id="why" value="Why both effects compound:&#xa;Multi-hop reasoning needs ALL k pieces simultaneously held in working memory of attention. Each piece &#xa;in the middle is hard to surface (Bias 1), AND wider gaps mean the model must maintain the chain across &#xa;more distractor tokens before joining (Bias 2). Re-rankers can only fight Bias 1; nothing in the literature&#xa;directly fights Bias 2 because the search space C(20,k) is intractable for k=4 (4845 orderings)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="310" width="1160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="impl" value="Practical implication for RAG / agent retrieval:&#xa;1. After retrieval, GROUP gold passages adjacently (cluster by topic/entity overlap before feeding LLM).&#xa;2. Don&#39;t rely on summarization to fix lost-in-middle — it linearises the curve at the cost of -15 to -30 pp.&#xa;3. CoT only helps when model is instruction-tuned; on raw long-context models CoT can collapse output." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;" vertex="1" parent="1">
          <mxGeometry x="20" y="430" width="1160" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
