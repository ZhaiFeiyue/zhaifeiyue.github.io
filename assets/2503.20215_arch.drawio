  <diagram id="page4" name="4. Speech Generation: DiT + BigVGAN">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="sg_codec" value="Single-stream codec tokens
(qwen-tts-tokenizer, vocab=8448)
@ ~25 Hz alignment grid" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="sg_emb" value="Codec Embedding
Embedding(8449 → 1024)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="60" width="280" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="sg_dit" value="Flow-Matching DiT
22 layers · d=1024 · 16 heads · head_dim=64
ff_mult=2 · dropout=0.1
mel_dim=80 (output)

Sliding-window block attention:
  receptive field = 4 blocks
  (2 lookback + current + 1 lookahead)
chunk-by-chunk streaming" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="60" width="540" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="sg_mel" value="Mel Spectrogram chunks
[B, 80, T_mel]" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="290" width="540" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="sg_bvg" value="Modified BigVGAN (vocoder)
upsample_rates [5, 3, 2, 2, 2, 2]
upsample_kernel_sizes [11, 7, 4, 4, 4, 4]
initial channels = 1536
resblock kernels [3, 7, 11]
chunk-by-chunk (fixed receptive field)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="380" width="540" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="sg_pcm" value="PCM Output
24 kHz · streaming" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="760" y="590" width="540" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="sg_train" value="Talker training (paper §3 + post-train):
1. Context / continuation training (ICL-style)
2. DPO for stability (LDPO objective)
   reward = WER + punctuation/pause metric
3. Multi-speaker instruction tuning
   timbre disentanglement" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="660" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="sg_diff" value="Δ vs Qwen3-Omni:
• Single codebook → 16 RVQ codebooks
• DiT vocoder → causal ConvNet (Code2Wav)
• Talker dense → MoE+Shared
• Audio rate 25 Hz → 12.5 Hz
• Whisper encoder → AuT (20M hr pretrain)
• Add Code Predictor (5L dense × 15 AR iters)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="660" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="t_t4" value="Qwen2.5-Omni Speech Generation — Single-codebook + DiT + BigVGAN" style="text;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1300" height="30" as="geometry"/>
        </mxCell>
