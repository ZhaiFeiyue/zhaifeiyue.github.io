  <diagram id="p4-rl" name="8. Long-horizon Coding RL Loop">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t4" value="Long-horizon coding RL loop (reconstructed from blog case studies — exact recipe not disclosed)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=17;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>

        <mxCell id="task" value="🎯 Task Proposer&#xa;• real OSS repo (Rust / Go / Python / Zig)&#xa;• devops, front-end, perf-opt, infra&#xa;• initial goal + success test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="env" value="🛠️ Execution Environment&#xa;• bash · file-edit · code-interpreter&#xa;• flame-graph profiler · CI · benchmarks&#xa;• reward signals: unit tests, throughput,&#xa;  latency, correctness, compile success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="agent" value="🤖 K2.6 Agent (policy)&#xa;context: full repo + history&#xa;up to 262K window · tool-calling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="580" y="180" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rollout" value="🌀 Long rollout (4-13h)&#xa;• 1000-4000+ tool calls&#xa;• 12-14 iteration rounds&#xa;• repo-scale 4000+ LoC edits&#xa;• explicit profile-driven replans" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="580" y="300" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="reward" value="🏆 Reward&#xa;• perf delta (MT/s, tok/s)&#xa;• tests passed / regressions caught&#xa;• edit locality &amp; avoids &quot;hacks&quot;&#xa;• instruction adherence&#xa;• tool-call success rate (Toolathlon flavor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="1100" y="260" width="240" height="130" as="geometry" />
        </mxCell>

        <mxCell id="update" value="🔄 Policy update&#xa;(inherits K2.5: token-level log-ratio clip&#xa; + KL penalty + MuonClip optimizer&#xa; + Toggle budget/full alternation)&#xa;— exact recipe not disclosed" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#475569;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="1100" y="430" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="e10" style="endArrow=classic;html=1" edge="1" parent="1" source="task" target="agent"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1" edge="1" parent="1" source="agent" target="rollout"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e12" style="endArrow=classic;html=1" edge="1" parent="1" source="rollout" target="env"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" style="endArrow=classic;html=1" edge="1" parent="1" source="env" target="reward"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" style="endArrow=classic;html=1" edge="1" parent="1" source="reward" target="update"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e15" style="endArrow=classic;html=1;strokeColor=#dc2626;strokeWidth=2" edge="1" parent="1" source="update" target="agent"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="cases" value="&lt;b&gt;Reported blog case studies (not formal benchmarks — evidence of long-horizon capability)&lt;/b&gt;&lt;br&gt;&lt;br&gt;(A) &lt;b&gt;Qwen3.5-0.8B Zig inference on Mac&lt;/b&gt;&lt;br&gt;&lt;span&gt;• 12h continuous · 4000+ tool calls · 14 iterations&lt;br&gt;• Throughput 15 → 193 tok/s (~13× gain), ~20% &gt; LM Studio&lt;br&gt;• Evidence: OOD language (Zig), realistic perf engineering, not synthetic sandbox&lt;/span&gt;&lt;br&gt;&lt;br&gt;(B) &lt;b&gt;exchange-core (8yr-old OSS matching engine)&lt;/b&gt;&lt;br&gt;&lt;span&gt;• 13h · 1000+ tool calls · 4000+ LoC modified · 12 strategy iterations&lt;br&gt;• CPU + allocation flame-graph analysis · thread topology rework (4ME+2RE → 2ME+1RE)&lt;br&gt;• Medium throughput +185% (0.43 → 1.24 MT/s); perf throughput +133% (1.23 → 2.86 MT/s)&lt;/span&gt;&lt;br&gt;&lt;br&gt;(C) &lt;b&gt;RL-infra on-call agent&lt;/b&gt;: 5-day autonomous operation · monitoring + incident response + cross-platform orchestration" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="460" width="960" height="360" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
