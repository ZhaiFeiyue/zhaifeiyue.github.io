  <diagram id="p4-rl" name="4. Long-horizon Coding RL Loop">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t4" value="Long-horizon coding RL loop (reconstructed from blog case studies — exact recipe not disclosed)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=17;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>

        <mxCell id="task" value="🎯 Task Proposer&#xa;• real OSS repo (Rust / Go / Python / Zig)&#xa;• devops, front-end, perf-opt, infra&#xa;• initial goal + success test" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="240" height="100" as="geometry" />
        </mxCell>

        <mxCell id="env" value="🛠️ Execution Environment&#xa;• bash · file-edit · code-interpreter&#xa;• flame-graph profiler · CI · benchmarks&#xa;• reward signals: unit tests, throughput,&#xa;  latency, correctness, compile success" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="agent" value="🤖 K2.6 Agent (policy)&#xa;context: full repo + history&#xa;up to 262K window · tool-calling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="580" y="180" width="240" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rollout" value="🌀 Long rollout (4-13h)&#xa;• 1000-4000+ tool calls&#xa;• 12-14 iteration rounds&#xa;• repo-scale 4000+ LoC edits&#xa;• explicit profile-driven replans" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="580" y="300" width="240" height="120" as="geometry" />
        </mxCell>

        <mxCell id="reward" value="🏆 Reward&#xa;• perf delta (MT/s, tok/s)&#xa;• tests passed / regressions caught&#xa;• edit locality &amp; avoids &quot;hacks&quot;&#xa;• instruction adherence&#xa;• tool-call success rate (Toolathlon flavor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="1100" y="260" width="240" height="130" as="geometry" />
        </mxCell>

