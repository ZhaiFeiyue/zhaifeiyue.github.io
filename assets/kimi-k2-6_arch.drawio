<mxfile host="app.diagrams.net" modified="2026-04-21T13:00:00.000Z" agent="paper-reader" version="24.0.0">
  <diagram id="p0-pipeline" name="1. Top-level Multimodal Pipeline">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t0" value="Kimi K2.6 — Top-level Multimodal Pipeline (verified from sglang/vllm modeling code)&#xa;KimiK25ForConditionalGeneration = MoonViT3dPretrainedModel + K2VLMultiModalProjector + DeepseekV3ForCausalLM" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1460" height="48" as="geometry" />
        </mxCell>

        &lt;!-- Text path --&gt;
        <mxCell id="txtIn" value="input_ids&#xa;[B, S_text]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="140" height="50" as="geometry" />
        </mxCell>
        <mxCell id="embed" value="embed_tokens&#xa;Embedding(163840 → 7168)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="190" width="200" height="55" as="geometry" />
        </mxCell>

        &lt;!-- Vision path --&gt;
        <mxCell id="imgIn" value="pixel_values + grid_thws&#xa;[N_patches, 3, 14, 14]&#xa;(NaViT-packed multi-res)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="350" y="90" width="220" height="70" as="geometry" />
        </mxCell>
        <mxCell id="vtower" value="&lt;b&gt;vision_tower = MoonViT3dPretrainedModel&lt;/b&gt;&lt;br&gt;• patch_embed: Conv2d(3, 1152, k=14, s=14)&lt;br&gt;• pos_emb: Learnable2DInterp divided_fixed (64×64×4)&lt;br&gt;• encoder: 27 × MoonViTEncoderLayer (d=1152, 16h, FFN=4304)&lt;br&gt;• merge: tpool_patch_merger (sd2_tpool, k=(2,2))&lt;br&gt;  → spatial 2×2 merge + temporal pool&lt;br&gt;output: [N_tok_img, 1152]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="320" y="185" width="290" height="140" as="geometry" />
        </mxCell>
        <mxCell id="mmproj" value="&lt;b&gt;mm_projector = K2VLMultiModalProjector&lt;/b&gt;&lt;br&gt;(sglang/kimi_k25.py:572-606)&lt;br&gt;• pre_norm: LayerNorm(1152)&lt;br&gt;• reshape: [N/4, 4608] (1152×2×2)&lt;br&gt;• linear_1: 4608 → 4608 (bias=T)&lt;br&gt;• act: GELU&lt;br&gt;• linear_2: 4608 → &lt;b&gt;7168&lt;/b&gt; (= text_hidden_size)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="320" y="350" width="290" height="140" as="geometry" />
        </mxCell>

        &lt;!-- Fusion point --&gt;
        <mxCell id="fuse" value="general_mm_embed_routine&#xa;scatter image embeds into text stream&#xa;at &lt;|kimi_k25_video_placeholder|&gt; tokens (id=163605)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="660" y="290" width="260" height="100" as="geometry" />
        </mxCell>

        &lt;!-- Language model --&gt;
        <mxCell id="lm" value="&lt;b&gt;language_model = DeepseekV3ForCausalLM&lt;/b&gt;&lt;br&gt;(sglang/deepseek_v2.py:1596 DeepseekV2DecoderLayer reused)&lt;br&gt;&#xa;layer 0 (dense, first_k_dense_replace=1):&lt;br&gt;&#xa;  DeepseekV2AttentionMLA(...) + DeepseekV2MLP(7168 → 18432 → 7168, SwiGLU)&lt;br&gt;&#xa;layers 1-60 (sparse, MoE):&lt;br&gt;&#xa;  DeepseekV2AttentionMLA(...) + &lt;b&gt;DeepseekV2MoE&lt;/b&gt;(384 routed top-8 + 1 shared)&lt;br&gt;&#xa;LayerNorm → &lt;b&gt;lm_head&lt;/b&gt; Linear(7168 → 163840) → logits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="970" y="200" width="500" height="240" as="geometry" />
        </mxCell>

        &lt;!-- Outputs --&gt;
        <mxCell id="out" value="hidden_states → logits&#xa;next-token / tool-call / text" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1160" y="500" width="200" height="60" as="geometry" />
        </mxCell>

        &lt;!-- Arrows --&gt;
        <mxCell id="ae1" style="endArrow=classic;html=1;strokeColor=#0284c7;strokeWidth=2" edge="1" parent="1" source="txtIn" target="embed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae2" style="endArrow=classic;html=1;strokeColor=#e11d48;strokeWidth=2" edge="1" parent="1" source="imgIn" target="vtower"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae3" style="endArrow=classic;html=1;strokeColor=#e11d48;strokeWidth=2" edge="1" parent="1" source="vtower" target="mmproj"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae4" style="endArrow=classic;html=1;strokeColor=#4338ca" edge="1" parent="1" source="embed" target="fuse"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae5" style="endArrow=classic;html=1;strokeColor=#ca8a04" edge="1" parent="1" source="mmproj" target="fuse"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae6" value="[B, S, 7168]" style="endArrow=classic;html=1;strokeColor=#7c3aed;strokeWidth=2;fontSize=10" edge="1" parent="1" source="fuse" target="lm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ae7" style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=2" edge="1" parent="1" source="lm" target="out"><mxGeometry relative="1" as="geometry" /></mxCell>

        &lt;!-- Legend / Notes --&gt;
        <mxCell id="legend1" value="&lt;b&gt;Code evidence&lt;/b&gt;&lt;br&gt;• sglang kimi_k25.py:678 KimiK25ForConditionalGeneration.__init__&lt;br&gt;• sglang kimi_k25.py:711 self.language_model = DeepseekV3ForCausalLM(config.text_config, ...)&lt;br&gt;• sglang kimi_k25.py:700 self.vision_tower = MoonViT3dPretrainedModel(config.vision_config, ...)&lt;br&gt;• sglang kimi_k25.py:709 self.mm_projector = K2VLMultiModalProjector(config.vision_config)&lt;br&gt;• sglang kimi_k25.py:774 forward() → general_mm_embed_routine (multimodal fusion utility)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#475569;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1420" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legend2" value="&lt;b&gt;K2.6 vs K2.5 diff @ pipeline level&lt;/b&gt;: HF modeling class name is still &lt;code&gt;KimiK25ForConditionalGeneration&lt;/code&gt; for K2.6 weights — code path is 100% reused. &lt;br&gt;Only difference: weight tensors are loaded through compressed-tensors INT4 dequant stub for routed MoE experts. The forward() graph shape is byte-identical to K2.5." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="1420" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="p1-decoder" name="2. K2.6 Decoder Layer (MLA + MoE)">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="dtitle" value="K2.6 Decoder Layer (DeepseekV2DecoderLayer) — Expanded internals from sglang/deepseek_v2.py&#xa;Layer 0 = dense (first_k_dense_replace=1) · Layers 1-60 = MoE (is_layer_sparse = layer_id ≥ 1)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1560" height="52" as="geometry" />
        </mxCell>

        &lt;!-- Input --&gt;
        <mxCell id="din" value="x ∈ ℝ^[B, S, 7168]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e0f2fe;strokeColor=#0284c7;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="680" y="90" width="240" height="50" as="geometry" />
        </mxCell>

        &lt;!-- Pre-norm --&gt;
        <mxCell id="dn1" value="input_layernorm&#xa;RMSNorm(7168, eps=1e-5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#475569;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="170" width="240" height="50" as="geometry" />
        </mxCell>

        &lt;!-- MLA block --&gt;
        <mxCell id="mlaBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="250" width="1440" height="460" as="geometry" />
        </mxCell>
        <mxCell id="mlaTitle" value="&lt;b&gt;DeepseekV2AttentionMLA&lt;/b&gt; (sglang/deepseek_v2.py:1130) — Multi-head Latent Attention, num_heads=64" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="100" y="260" width="1400" height="28" as="geometry" />
        </mxCell>

        &lt;!-- Q path --&gt;
        <mxCell id="qap" value="q_a_proj&#xa;Linear(7168 → 1536)&#xa;&lt;b&gt;q_lora_rank&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1e3a8a;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="120" y="310" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="qan" value="q_a_layernorm&#xa;RMSNorm(1536)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1e3a8a;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="120" y="390" width="180" height="50" as="geometry" />
        </mxCell>
        <mxCell id="qbp" value="q_b_proj&#xa;Linear(1536 → 64×(128+64))&#xa;= 12288, ColumnParallel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#1e3a8a;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="120" y="460" width="180" height="60" as="geometry" />
        </mxCell>
        <mxCell id="qsplit" value="reshape → split&#xa;Q_nope [h=64, d=128]&#xa;Q_rope [h=64, d=64]" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="120" y="540" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="qrope" value="RoPE(Q_rope)&#xa;rotary_dim=64&#xa;θ=50000, YaRN f=64&#xa;(only on _rope half)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="120" y="640" width="180" height="60" as="geometry" />
        </mxCell>

        &lt;!-- KV path --&gt;
        <mxCell id="kvap" value="kv_a_proj_with_mqa&#xa;Replicated Linear(7168 → 576)&#xa;= &lt;b&gt;kv_lora(512) + qk_rope(64)&lt;/b&gt;&lt;br&gt;(fused with q_a via fused_qkv_a_proj_with_mqa)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="310" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="kvsplit" value="split: c_kv [.., 512] · k_pe [.., 64]" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="400" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="kvan" value="kv_a_layernorm&#xa;RMSNorm(512)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="460" width="220" height="50" as="geometry" />
        </mxCell>
        <mxCell id="kvbp" value="kv_b_proj&#xa;Linear(512 → 64×(128+128))&#xa;= &lt;b&gt;K_nope + V&lt;/b&gt;, ColumnParallel" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="520" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="kvout" value="K_nope [64,128] + K_rope [1,64 shared]&#xa;V [64,128]&#xa;&lt;br&gt;&lt;b&gt;KV cache: 576 fp/token (512 c_kv + 64 k_pe)&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fce7f3;strokeColor=#db2777;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="380" y="600" width="220" height="80" as="geometry" />
        </mxCell>

        &lt;!-- attn core --&gt;
        <mxCell id="attn" value="&lt;b&gt;Attention core (absorb path)&lt;/b&gt;&lt;br&gt;softmax((Q · K^T) / √192) · V&#xa;qk_head_dim = 128+64 = 192&#xa;v_head_dim = 128&#xa;heads = 64 (no GQA, MLA compresses via kv_lora)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="700" y="450" width="360" height="120" as="geometry" />
        </mxCell>

        &lt;!-- o_proj --&gt;
        <mxCell id="oproj" value="o_proj&#xa;RowParallel Linear(64×128 → 7168)&#xa;= 8192 → 7168" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=10" vertex="1" parent="1">
          <mxGeometry x="1160" y="460" width="240" height="60" as="geometry" />
        </mxCell>

        &lt;!-- residual --&gt;
        <mxCell id="res1" value="x + attn(x)&#xa;(residual)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="700" y="740" width="240" height="60" as="geometry" />
        </mxCell>

        &lt;!-- Post-norm --&gt;
        <mxCell id="dn2" value="post_attention_layernorm&#xa;RMSNorm(7168, eps=1e-5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#475569;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="680" y="830" width="240" height="50" as="geometry" />
        </mxCell>

        &lt;!-- MoE block --&gt;
        <mxCell id="moeBox" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff7ed;strokeColor=#ea580c;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="910" width="1440" height="370" as="geometry" />
        </mxCell>
        <mxCell id="moeTitle" value="&lt;b&gt;DeepseekV2MoE&lt;/b&gt; (sglang/deepseek_v2.py:354) — Layers 1-60 only; Layer 0 = DeepseekV2MLP(7168→18432→7168 SwiGLU)" style="text;html=1;fillColor=none;strokeColor=none;fontSize=13;fontStyle=1;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="100" y="920" width="1400" height="28" as="geometry" />
        </mxCell>

        <mxCell id="gate" value="&lt;b&gt;MoEGate&lt;/b&gt; (noaux_tc)&lt;br&gt;F.linear(x, weight[384, 7168])&lt;br&gt;+ e_score_correction_bias [384]&lt;br&gt;&lt;b&gt;sigmoid&lt;/b&gt; scoring&lt;br&gt;→ top-8 selection&lt;br&gt;&lt;br&gt;weight dtype = FP16 (NOT INT4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="120" y="960" width="230" height="150" as="geometry" />
        </mxCell>

        <mxCell id="routed" value="&lt;b&gt;384 routed experts&lt;/b&gt; (top-8 active)&lt;br&gt;each expert = DeepseekV2MLP(7168 → 2048 → 7168) SwiGLU&lt;br&gt;routed_scaling_factor = 2.827&lt;br&gt;total routed params: 384 × 3 × (7168×2048) / 2 ≈ 940 GB FP16 per-layer&lt;br&gt;&lt;br&gt;&lt;b&gt;🔴 INT4 compressed-tensors here&lt;/b&gt;&lt;br&gt;   (group_size=32, symmetric, pack-quantized)&lt;br&gt;   pattern: re:.*mlp.experts.*&lt;br&gt;   NOT in ignore list" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dbeafe;strokeColor=#dc2626;strokeWidth=3;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="390" y="960" width="450" height="200" as="geometry" />
        </mxCell>

        <mxCell id="shared" value="&lt;b&gt;1 shared expert&lt;/b&gt; (always active)&lt;br&gt;DeepseekV2MLP(7168 → 2048 → 7168) SwiGLU&lt;br&gt;intermediate_size = moe_intermediate_size × n_shared_experts = 2048&lt;br&gt;&lt;br&gt;&lt;b&gt;🟢 FP16 kept&lt;/b&gt; — pattern: re:.*shared_experts.*&lt;br&gt;   IS in ignore list of quantization_config&lt;br&gt;   (每 token 必经, 量化误差敏感)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="880" y="960" width="430" height="160" as="geometry" />
        </mxCell>

        <mxCell id="combine" value="combine&#xa;topk_output · routed_experts(x)&#xa;+ shared_experts(x) · α&#xa;(α = fused_shared_experts_scaling_factor)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="600" y="1180" width="340" height="80" as="geometry" />
        </mxCell>

        <mxCell id="res2" value="x + MoE(x)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="700" y="1300" width="200" height="60" as="geometry" />
        </mxCell>

        &lt;!-- Arrows --&gt;
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="din" target="dn1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="dn1" target="qap"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="dn1" target="kvap"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="qap" target="qan"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="qan" target="qbp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="qbp" target="qsplit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="qsplit" target="qrope"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="kvap" target="kvsplit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="kvsplit" target="kvan"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="kvan" target="kvbp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="kvbp" target="kvout"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="qrope" target="attn"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="kvout" target="attn"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="attn" target="oproj"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=2" edge="1" parent="1" source="oproj" target="res1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="res1" target="dn2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="dn2" target="gate"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="dn2" target="shared"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="gate" target="routed"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="routed" target="combine"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="shared" target="combine"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=2" edge="1" parent="1" source="combine" target="res2"><mxGeometry relative="1" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="p2-moonvit" name="3. MoonViT-3D Vision Tower">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="vtitle" value="MoonViT-3D Vision Tower — From vllm/kimi_k25_vit.py + sglang/kimi_k25.py&#xa;27 layers · d=1152 · 16 heads × 72 head_dim · FFN=4304 · patch=14 · sd2_tpool 2×2 merge" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1460" height="50" as="geometry" />
        </mxCell>

        <mxCell id="vin" value="pixel_values + grid_thws&#xa;(T, H, W) packed batch&#xa;NaViT-style multi-res packing&#xa;T=1 image, T=4 video (4 frames bundled)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontSize=11;fontStyle=1;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="260" height="80" as="geometry" />
        </mxCell>

        <mxCell id="vpe" value="&lt;b&gt;MoonVision3dPatchEmbed&lt;/b&gt;&lt;br&gt;(vllm/kimi_k25_vit.py:183)&lt;br&gt;Conv2d(3 → 1152, k=14, s=14, bias=T)&lt;br&gt;+ Learnable2DInterpPosEmbDivided_fixed&lt;br&gt;(64×64 spatial grid × 4 time bins, divided_fixed)&lt;br&gt;→ [N_patches, 1152]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="380" y="90" width="320" height="120" as="geometry" />
        </mxCell>

        <mxCell id="venc" value="&lt;b&gt;MoonViT3dEncoder&lt;/b&gt; (27 × MoonViTEncoderLayer)&lt;br&gt;(vllm/kimi_k25_vit.py:340, 463)&lt;br&gt;&lt;br&gt;for layer in 0..26:&lt;br&gt;  x = x + Attention(RMSNorm(x))&lt;br&gt;     ├─ qkv_proj (1152 → 3456, bias=T) → split QKV&lt;br&gt;     ├─ Rope2DPosEmbRepeated on Q,K (2D RoPE, repeated per head)&lt;br&gt;     ├─ spatial_temporal attention (video_attn_type)&lt;br&gt;     │   — inter-frame 注意力沿 T, H, W 三维展开&lt;br&gt;     └─ o_proj (1152 → 1152)&lt;br&gt;  x = x + MLP2(RMSNorm(x))&lt;br&gt;     ├─ w1: Linear(1152 → 4304)&lt;br&gt;     ├─ gelu_pytorch_tanh activation&lt;br&gt;     └─ w2: Linear(4304 → 1152)&lt;br&gt;output: [N_patches, 1152]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="780" y="90" width="500" height="300" as="geometry" />
        </mxCell>

        <mxCell id="vmerge" value="&lt;b&gt;tpool_patch_merger&lt;/b&gt; (sd2_tpool)&lt;br&gt;(vllm/kimi_k25_vit.py:523)&lt;br&gt;&lt;br&gt;spatial downsample 2×2:&lt;br&gt;  reshape [T, H, W, 1152] → [T, H/2, W/2, 1152×4=4608]&lt;br&gt;temporal pool (video only):&lt;br&gt;  mean over T=4 frames&lt;br&gt;  → [1, H/2, W/2, 4608]&lt;br&gt;&lt;br&gt;output: N_tok_merged × 4608&lt;br&gt;(video token count = image / 4 / 4 = /16)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fde68a;strokeColor=#ca8a04;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="380" y="260" width="320" height="200" as="geometry" />
        </mxCell>

        <mxCell id="vproj" value="&lt;b&gt;K2VLMultiModalProjector&lt;/b&gt;&lt;br&gt;(sglang/kimi_k25.py:572)&lt;br&gt;&lt;br&gt;pre_norm: LayerNorm(1152, eps=1e-5)&lt;br&gt;(applied before reshape)&lt;br&gt;reshape: view(-1, vt_hidden×merge_h×merge_w) = [..., 4608]&lt;br&gt;&lt;br&gt;linear_1: ReplicatedLinear(4608 → 4608, bias=T)&lt;br&gt;act: GELU()&lt;br&gt;linear_2: ReplicatedLinear(4608 → &lt;b&gt;text_hidden_size=7168&lt;/b&gt;, bias=T)&lt;br&gt;&lt;br&gt;output: [N_tok, 7168] ← 进入 LLM 流" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="780" y="440" width="500" height="230" as="geometry" />
        </mxCell>

        <mxCell id="vout" value="image / video embeds&#xa;[N_tok_img, 7168]&#xa;&#xa;scattered into text stream&#xa;at &lt;|kimi_k25_video_placeholder|&gt;&#xa;(token id = 163605)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="700" width="260" height="120" as="geometry" />
        </mxCell>

        &lt;!-- Arrows --&gt;
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="vin" target="vpe"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="vpe" target="venc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="venc" target="vmerge"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1" edge="1" parent="1" source="vmerge" target="vproj"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell style="endArrow=classic;html=1;strokeColor=#16a34a;strokeWidth=2" edge="1" parent="1" source="vproj" target="vout"><mxGeometry relative="1" as="geometry" /></mxCell>

        <mxCell id="vnote" value="&lt;b&gt;Key design choices (verified from code):&lt;/b&gt;&lt;br&gt;• &lt;b&gt;head_dim = 72&lt;/b&gt; (non-power-of-2, inherited from SigLIP-SO-400M): 1152 / 16 = 72&lt;br&gt;• &lt;b&gt;2D RoPE&lt;/b&gt; applied on Q,K inside each encoder layer; video uses time bin index via divided_fixed pos emb&lt;br&gt;• &lt;b&gt;GELU pytorch_tanh&lt;/b&gt; activation (not swiglu — vision tower uses conventional FFN)&lt;br&gt;• &lt;b&gt;attn_bias=True&lt;/b&gt; in vision layers (contrast to text transformer which is bias-free)&lt;br&gt;• &lt;b&gt;video_attn_type=&quot;spatial_temporal&quot;&lt;/b&gt;: attention computed across T, H, W all three axes&lt;br&gt;• &lt;b&gt;Merge is sd2_tpool&lt;/b&gt;: spatial 2× downsample + temporal pooling ALL frames (not just mean 4 frames)&lt;br&gt;• &lt;b&gt;Projector does the dim promotion 4608 → 7168&lt;/b&gt; with a single MLP, hence &quot;patchmerger&quot; in config" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#475569;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="860" width="1420" height="180" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="p3-quant" name="4. INT4 Quantization Layout">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="qtitle" value="K2.6 `quantization_config` layout — what is INT4, what stays FP16&#xa;compressed-tensors pack-quantized · INT4 symmetric · group_size=32 · observer=minmax" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1460" height="48" as="geometry" />
        </mxCell>

        <mxCell id="qconfig" value="&lt;b&gt;config.json &quot;quantization_config&quot;:&lt;/b&gt;&#xa;{&lt;br&gt;  &quot;quant_method&quot;: &quot;compressed-tensors&quot;,&lt;br&gt;  &quot;format&quot;: &quot;pack-quantized&quot;,&#xa;  &quot;quantization_status&quot;: &quot;compressed&quot;,&#xa;  &quot;config_groups&quot;: {&#xa;    &quot;group_0&quot;: {&#xa;      &quot;targets&quot;: [&quot;Linear&quot;],&#xa;      &quot;weights&quot;: { num_bits: 4, type: int, symmetric: true, strategy: group, group_size: 32, observer: minmax }&#xa;    }&#xa;  },&#xa;  &quot;ignore&quot;: [&#xa;    &quot;lm_head&quot;,&#xa;    &quot;re:.*self_attn.*&quot;,&#xa;    &quot;re:.*shared_experts.*&quot;,&#xa;    &quot;re:.*mlp\\.(gate|up|gate_up|down)_proj.*&quot;&#xa;  ],&#xa;  &quot;kv_cache_scheme&quot;: null&#xa;}" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8fafc;strokeColor=#475569;fontFamily=Courier New;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="60" y="110" width="540" height="400" as="geometry" />
        </mxCell>

        &lt;!-- INT4 target --&gt;
        <mxCell id="int4" value="&lt;b&gt;🔴 INT4 (compressed)&lt;/b&gt;&lt;br&gt;only pattern NOT in ignore list:&lt;br&gt;&lt;code&gt;model.layers.N.mlp.experts.[0-383].(gate_proj|up_proj|down_proj)&lt;/code&gt;&lt;br&gt;&#xa;= 60 MoE layers × 384 experts × 3 proj&lt;br&gt;&#xa;&lt;br&gt;FP16 size: 60 × 384 × 3 × (7168×2048)/2 ≈ &lt;b&gt;925 GB&lt;/b&gt;&lt;br&gt;&#xa;INT4 size (g=32, 4b w + fp16 scale per 32): ≈ &lt;b&gt;245 GB&lt;/b&gt;&lt;br&gt;&#xa;→ &lt;b&gt;~3.77× shrink&lt;/b&gt; on the dominant param block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fee2e2;strokeColor=#dc2626;strokeWidth=2;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="650" y="110" width="810" height="160" as="geometry" />
        </mxCell>

        <mxCell id="kept" value="&lt;b&gt;🟢 FP16 kept (matched by ignore patterns)&lt;/b&gt;&lt;br&gt;&lt;br&gt;• &lt;b&gt;self_attn&lt;/b&gt; (MLA 所有投影)：q_a_proj / q_b_proj / kv_a_proj_with_mqa / kv_a_layernorm / kv_b_proj / o_proj&lt;br&gt;&#xa;   └ 61 layers × (q_a 7168×1536 + q_b 1536×12288 + kv_a 7168×576 + kv_b 512×16384 + o 8192×7168) ≈ &lt;b&gt;44 GB FP16&lt;/b&gt;&lt;br&gt;&#xa;&lt;br&gt;&#xa;• &lt;b&gt;shared_experts&lt;/b&gt;：1 shared expert × 60 layers × 3 × 7168×2048 / 2 ≈ &lt;b&gt;2.5 GB FP16&lt;/b&gt; (每 token 必经)&lt;br&gt;&#xa;&lt;br&gt;&#xa;• &lt;b&gt;mlp.(gate|up|down)_proj&lt;/b&gt;：匹配 layer 0 的 dense FFN DeepseekV2MLP&lt;br&gt;&#xa;   └ 1 层 × 3 × 7168×18432 / 2 ≈ &lt;b&gt;0.8 GB FP16&lt;/b&gt;&lt;br&gt;&#xa;&lt;br&gt;&#xa;• &lt;b&gt;lm_head&lt;/b&gt;：Linear(7168 → 163840) ≈ &lt;b&gt;2.35 GB FP16&lt;/b&gt;&lt;br&gt;&#xa;• &lt;b&gt;embed_tokens&lt;/b&gt;：Embedding(163840, 7168) ≈ &lt;b&gt;2.35 GB FP16&lt;/b&gt; (tied? tie_word_embeddings=false, 独立参数)&lt;br&gt;&#xa;• &lt;b&gt;RMSNorm 参数 + gate (MoEGate) + gate bias&lt;/b&gt; ≈ 0.5 GB FP16&lt;br&gt;&#xa;• &lt;b&gt;MoonViT-3D + mm_projector&lt;/b&gt; ≈ 1 GB FP16 (not Linear targets in config)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;strokeWidth=2;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="650" y="290" width="810" height="360" as="geometry" />
        </mxCell>

        <mxCell id="total" value="&lt;b&gt;Total deployed size ≈ 245 GB (INT4 MoE experts) + ~53 GB (FP16 rest) = ~298 GB&lt;/b&gt; 【含 embedding/scale 开销的估算】&lt;br&gt;Fits: single 8× H200 (141 GB×8 = 1128 GB) — ample headroom for 262K KV cache across dozens of concurrent streams&lt;br&gt;Tight but possible: single 8× H100 80 GB (640 GB) — KV cache budget becomes the limit at high concurrency&lt;br&gt;&lt;br&gt;&lt;b&gt;KV cache scheme = null&lt;/b&gt; → KV cache 仍是 FP16 (MLA latent 576 fp/token, 262K ctx ≈ 290 MB/seq — MLA 本就足够紧凑, 不需要 KV 量化)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="680" width="1400" height="170" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="p1-overview" name="5. K2.6 Release Overview">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="Kimi K2.6 — What actually changed vs K2.5&#xa;(架构完全相同, deltas 在训练 + 量化 + 编排)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="50" as="geometry" />
        </mxCell>

        <mxCell id="archBox" value="&lt;b&gt;Model Architecture (IDENTICAL to K2.5)&lt;/b&gt;&lt;br&gt;DeepseekV3ForCausalLM · 61 layers · d_model=7168&lt;br&gt;MLA: 64 heads · q_lora=1536 · kv_lora=512 · qk_nope/rope/v=128/64/128&lt;br&gt;MoE: 384 routed top-8 + 1 shared expert · expert hidden=2048 · sigmoid+noaux_tc&lt;br&gt;FFN (layer 0): dense 18432 · SwiGLU · RMSNorm · vocab=163840&lt;br&gt;YaRN factor=64 · 4096 → 262144 context · rope_theta=50000&lt;br&gt;Vision: MoonViT-3D 27L · d=1152 · 16 heads · patch=14 · sd2_tpool 2×2 merge&lt;br&gt;Total ≈ 1.04T params · Active ≈ 32B" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2ff;strokeColor=#4338ca;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="90" width="640" height="180" as="geometry" />
        </mxCell>

        <mxCell id="quantBox" value="&lt;b&gt;🆕 Delta 1: Default INT4 release (compressed-tensors)&lt;/b&gt;&lt;br&gt;• &lt;b&gt;pack-quantized INT4 symmetric&lt;/b&gt; per-group (group_size=32)&lt;br&gt;• &lt;b&gt;quantization_status: &quot;compressed&quot;&lt;/b&gt; (ships as INT4)&lt;br&gt;• &lt;b&gt;Ignore list&lt;/b&gt;: lm_head · self_attn · shared_experts · mlp.(gate|up|down)_proj&lt;br&gt;   → routed MoE experts (~98% of params) 4-bit, attention + shared FP16&lt;br&gt;• K2.5 HF card was BF16-first; K2.6 default is INT4 → 1.04T → ~260GB weights&lt;br&gt;• Fits a single 8× H100/H200 node without heroic sharding" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="720" y="90" width="640" height="180" as="geometry" />
        </mxCell>

        <mxCell id="trainBox" value="&lt;b&gt;🆕 Delta 2: Long-horizon agentic RL training&lt;/b&gt;&lt;br&gt;• Target capability: &lt;b&gt;hours-long coding sessions with 1K-4K tool calls&lt;/b&gt;&lt;br&gt;• Reported case: Zig inference optimization, &lt;b&gt;12h · 4000+ tools · 14 iterations&lt;/b&gt;, 15 → 193 tok/s (~20% &gt; LM Studio)&lt;br&gt;• Reported case: exchange-core refactor, &lt;b&gt;13h · 1000+ tools · 4000 LoC · 12 strategies&lt;/b&gt; → 185% / 133% throughput gains&lt;br&gt;• Bench: &lt;b&gt;Kimi Code Bench&lt;/b&gt; internal suite (Rust / Go / Python, front-end / devops / perf)&lt;br&gt;• Post-training recipe: [inherits K2.5 MuonClip + token-level log-ratio clip + KL]&lt;br&gt;• Blog does not disclose total tokens, GPU-hours, or exact objective — [未披露]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="640" height="200" as="geometry" />
        </mxCell>

        <mxCell id="swarmBox" value="&lt;b&gt;🆕 Delta 3: Agent Swarm scaled 3×&lt;/b&gt;&lt;br&gt;• K2.5: up to &lt;b&gt;100 sub-agents · 1500 steps&lt;/b&gt; (research preview)&lt;br&gt;• K2.6: up to &lt;b&gt;300 sub-agents · 4000 steps&lt;/b&gt; concurrent&lt;br&gt;• PARL-trained orchestrator + frozen sub-agents (inherited from K2.5)&lt;br&gt;• New: &lt;b&gt;Skills&lt;/b&gt; — ingest high-quality PDFs / slides / sheets,&lt;br&gt;   capture &quot;structural + stylistic DNA&quot;, replay on future tasks&lt;br&gt;• New: &lt;b&gt;Claw Groups&lt;/b&gt; — heterogeneous agents (any model, any device)&lt;br&gt;   coordinated by K2.6 as adaptive router + failure handler" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe4e6;strokeColor=#e11d48;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="720" y="290" width="640" height="200" as="geometry" />
        </mxCell>

        <mxCell id="benchBox" value="&lt;b&gt;📊 Benchmark deltas K2.5 → K2.6 (all tool-augmented)&lt;/b&gt;&lt;br&gt;Agent:   BrowseComp 74.9 → 83.2 · BrowseComp(swarm) 78.4 → 86.3 · Toolathlon 27.8 → 50.0 · MCPMark 29.5 → 55.9 · OSWorld-Verified 63.3 → 73.1&lt;br&gt;Coding:  Terminal-Bench 2.0 50.8 → 66.7 · SWE-Bench Pro 50.7 → 58.6 · SWE-Bench Multilingual 73.0 → 76.7 · SWE-Bench Verified 76.8 → 80.2 · LiveCodeBench v6 85.0 → 89.6&lt;br&gt;Reasoning: HLE-Full 30.1 → 34.7 · HLE-Full w/ tools 50.2 → 54.0 · AIME 2026 95.8 → 96.4 · HMMT 2026 87.1 → 92.7 · GPQA-Diamond 87.6 → 90.5&lt;br&gt;Vision:  MMMU-Pro 78.5 → 79.4 · BabyVision 36.5 → 39.8 · V* w/ python 86.9 → 96.9&#xa;Key qualitative: &lt;b&gt;Toolathlon +80%&lt;/b&gt;, &lt;b&gt;MCPMark +89%&lt;/b&gt;, &lt;b&gt;Terminal-Bench +31%&lt;/b&gt; — agentic tool use is the BIG jump" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=11;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="1320" height="170" as="geometry" />
        </mxCell>

        <mxCell id="noteBox" value="&lt;b&gt;核心判断&lt;/b&gt;: Kimi K2.6 是 K2.5 的 &lt;b&gt;post-training + 量化 + orchestration release&lt;/b&gt;, NOT a new foundation model.&lt;br&gt;HuggingFace config.json 与 K2.5 的关键维度 &lt;b&gt;逐字相同&lt;/b&gt;(除 quantization_config 新增)。主要价值在 RL / agentic 层面的 scale-out:&lt;br&gt;(1) 把长程 coding session 从 &quot;分钟级&quot; 推到 &quot;小时级&quot;(4-13h连续工具调用); (2) Agent Swarm 3× 横向扩展; (3) Claw Groups 打开异构 agent 生态." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f1f5f9;strokeColor=#475569;fontSize=12;align=left;verticalAlign=top;spacingLeft=10;spacingTop=6;fontStyle=0" vertex="1" parent="1">
          <mxGeometry x="40" y="700" width="1320" height="110" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="p2-swarm" name="6. Agent Swarm Scaling">
    <mxGraphModel dx="1600" dy="900" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t2" value="Agent Swarm scaling: K2.5 (100 × 1500) → K2.6 (300 × 4000)" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1320" height="40" as="geometry" />
        </mxCell>

        <mxCell id="k25label" value="Kimi K2.5 Agent Swarm (research preview)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#fef3c7;strokeColor=#ca8a04;rounded=1" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="520" height="30" as="geometry" />
        </mxCell>
        <mxCell id="k26label" value="Kimi K2.6 Agent Swarm (GA)" style="text;html=1;fontSize=14;fontStyle=1;fillColor=#dcfce7;strokeColor=#16a34a;rounded=1" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="520" height="30" as="geometry" />
        </mxCell>

        <mxCell id="k25orch" value="K2.5 Orchestrator&#xa;(PARL-trained)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="280" y="130" width="120" height="60" as="geometry" />
        </mxCell>
        <mxCell id="k25sub" value="≤ 100 frozen sub-agents&#xa;heterogeneous skills&#xa;max ~1500 steps / run" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9c3;strokeColor=#ca8a04;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="200" y="230" width="280" height="70" as="geometry" />
        </mxCell>

        <mxCell id="k25metric" value="&lt;b&gt;K2.5 reported ceilings&lt;/b&gt;&lt;br&gt;• Parallel sub-agents: 100&lt;br&gt;• Coordinated steps: 1500&lt;br&gt;• BrowseComp (swarm): 78.4&lt;br&gt;• 3-4.5× latency reduction&lt;br&gt;• Outputs: narrow (search / report)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fffbeb;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="80" y="330" width="520" height="120" as="geometry" />
        </mxCell>

        <mxCell id="k26orch" value="K2.6 Orchestrator&#xa;(PARL + Skills + failure handler)" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dcfce7;strokeColor=#16a34a;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="990" y="125" width="160" height="70" as="geometry" />
        </mxCell>
        <mxCell id="k26sub" value="≤ 300 sub-agents&#xa;compositional (search+research, analysis+write, multi-format gen)&#xa;max ~4000 coordinated steps" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d1fae5;strokeColor=#16a34a;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="860" y="230" width="420" height="90" as="geometry" />
        </mxCell>

        <mxCell id="k26skills" value="🆕 &lt;b&gt;Skills&lt;/b&gt; (structural + stylistic DNA)&lt;br&gt;Ingest PDF / slides / sheets / docs → reusable skill&#xa;e.g. &quot;McKinsey PPT style&quot;, &quot;astro-paper visual style&quot;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef3c7;strokeColor=#ca8a04;fontSize=11;align=left;verticalAlign=top;spacingLeft=6;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="860" y="335" width="420" height="60" as="geometry" />
        </mxCell>

        <mxCell id="k26metric" value="&lt;b&gt;K2.6 reported ceilings&lt;/b&gt;&lt;br&gt;• Parallel sub-agents: 300 (3.0×)&lt;br&gt;• Coordinated steps: 4000 (2.67×)&lt;br&gt;• BrowseComp (swarm): 86.3 (+7.9 absolute)&lt;br&gt;• Outputs: docs + websites + slides + sheets in one run&lt;br&gt;• Sample runs: 100 custom resumes · 5 quant strategies × 100 semiconductor assets · 7000-word astro paper + 14 charts + 20K-entry dataset" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ecfdf5;strokeColor=#16a34a;fontSize=11;align=left;verticalAlign=top;spacingLeft=8;spacingTop=4" vertex="1" parent="1">
          <mxGeometry x="800" y="430" width="520" height="150" as="geometry" />
        </mxCell>

        <mxCell id="arrow1" value="3× wider · 2.67× deeper · +7.9 abs BrowseComp" style="endArrow=classic;html=1;strokeColor=#7c3aed;strokeWidth=3;fontSize=12;fontStyle=1" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="620" y="250" as="sourcePoint" />
            <mxPoint x="840" y="250" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <mxCell id="whyBox" value="&lt;b&gt;为什么敢推到 300 × 4000?&lt;/b&gt;&lt;br&gt;1. 子 agent frozen (无 gradient) → 推理侧只要更多算力, 不重训&lt;br&gt;2. Orchestrator 已在 K2.5 PARL 阶段学到如何 shard context, failure 时重分配&lt;br&gt;3. 新引入 Skills 让 subagent 可复用结构化模板, 降低每 step cognitive load&lt;br&gt;4. Long-horizon coding RL 同期让 orchestrator 本身有 &quot;坚持 4000 步不崩&quot; 的能力" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f3ff;strokeColor=#7c3aed;fontSize=12;align=left;verticalAlign=top;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="620" width="1240" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

