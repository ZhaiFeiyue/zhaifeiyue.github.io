<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-19" agent="paper-reader" version="24.0" type="device">

  <!-- Page 1: PrfaaS-PD Topology (status quo vs PrfaaS) -->
  <diagram id="page1" name="1. Status quo vs PrfaaS">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="PrfaaS = decouple PD across datacenters: hybrid attention shrinks KV → cross-DC Ethernet becomes feasible" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1620" height="30" as="geometry"/>
        </mxCell>

        <!-- LEFT: Status quo single-cluster -->
        <mxCell id="lq_box" value="Status Quo: Single tightly-coupled RDMA datacenter (PD must share fabric)" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="700" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="lq_pre" value="Prefill (compute-dense)&#xa;e.g. H200 / Rubin CPX&#xa;Generates KVCache → emits 60 Gbps/inst at 32K (dense)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="160" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="lq_dec" value="Decode (BW-dense)&#xa;e.g. H20 / LPU&#xa;HBM-bandwidth bound, low compute use" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="420" y="160" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="lq_arrow" value="KVCache transfer&#xa;needs RDMA-class&#xa;(IB / NVLink / 800Gbps)" style="endArrow=classic;html=1;strokeWidth=4;strokeColor=#d62728;fontSize=11;fontStyle=1;" edge="1" parent="1" source="lq_pre" target="lq_dec">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="lq_kv" value="KV Store (cluster-local, RDMA fabric)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="340" width="620" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="lq_pain" value="Pain points:&#xa;• Heterogeneous chips MUST co-locate behind same RDMA island&#xa;• Prefill:Decode hardware ratio fixed once deployed&#xa;• Dense KV at 32K = 3.8 Tbps for 512×H200 cluster — locks deployment to single DC&#xa;• Cannot reassign chip-types as traffic shifts (specialised hw)" style="rounded=0;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="440" width="620" height="200" as="geometry"/>
        </mxCell>

        <!-- RIGHT: PrfaaS multi-cluster -->
        <mxCell id="rq_box" value="PrfaaS-PD: prefill cluster + decode cluster decoupled across DCs (commodity Ethernet)" style="rounded=1;whiteSpace=wrap;fillColor=#e6f5e6;strokeColor=#2e7d32;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="780" y="80" width="880" height="600" as="geometry"/>
        </mxCell>

        <mxCell id="rq_pre" value="Standalone PrfaaS Cluster&#xa;(compute-dense, e.g. 32×H200)&#xa;handles long uncached prefill (l &gt; t)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="150" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="rq_pd" value="Local PD Cluster&#xa;(64×H20, RDMA inside)&#xa;short prefill + decode; PD ratio adjustable" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1340" y="150" width="280" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="rq_eth" value="Cross-DC Ethernet&#xa;~100 Gbps VPC peering&#xa;hybrid KV @ 13 Gbps avg (13% util)" style="rounded=0;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1140" y="170" width="160" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="rq_e1" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#2e7d32;" edge="1" parent="1" source="rq_pre" target="rq_eth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="rq_e2" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#2e7d32;" edge="1" parent="1" source="rq_eth" target="rq_pd"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="rq_router" value="Request Router&#xa;length-based: l &gt; t → PrfaaS, else local PD-P&#xa;cache-aware + bandwidth-aware (dual-timescale)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="980" y="320" width="500" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="rq_kv" value="Hybrid Prefix Cache Pool&#xa;(linear-attn states: request-level, full-attn KV: block-level, unified backing pool)" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="430" width="800" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="rq_global" value="Global KVCache Manager — tracks block locations across all clusters; computes per-cluster prefix-match per request" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="820" y="510" width="800" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="rq_win" value="Why feasible NOW?&#xa;• Hybrid attention (KDA / SWA / linear) ↓ KV by 13× (32K MiMo) up to 36× (Ring-2.5-1T)&#xa;• Per-instance Φ_kv drops from ~60 Gbps → ~3-5 Gbps&#xa;• Selective offloading (l &gt; t) keeps cross-DC traffic small&#xa;• Result: 54% throughput vs homogeneous PD at equal hardware count" style="rounded=0;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#2e7d32;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="820" y="580" width="800" height="80" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- Page 2: PrfaaS-PD Three-Subsystem Topology -->
  <diagram id="page2" name="2. PrfaaS-PD Subsystems">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="PrfaaS-PD architecture = 3 subsystems × 2 cluster types — compute + network + storage" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1500" height="30" as="geometry"/>
        </mxCell>

        <!-- User + Router on top -->
        <mxCell id="user" value="User Requests" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="80" y="80" width="180" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="router" value="Request Router&#xa;(global scheduler)&#xa;routes by: incremental length l, prefix cache locations,&#xa;cross-cluster bandwidth utilization" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="420" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="er1" style="endArrow=classic;html=1;" edge="1" parent="1" source="user" target="router"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Row labels (subsystems) -->
        <mxCell id="rowL_compute" value="Compute Subsystem" style="rounded=0;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="20" y="280" width="160" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="rowL_net" value="Network Subsystem" style="rounded=0;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="20" y="500" width="160" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="rowL_stor" value="Storage Subsystem" style="rounded=0;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;fontStyle=1;rotation=-90;" vertex="1" parent="1">
          <mxGeometry x="20" y="720" width="160" height="30" as="geometry"/>
        </mxCell>

        <!-- PrfaaS Cluster column -->
        <mxCell id="prfaas_box" value="PrfaaS Cluster (Long Request, l &gt; t)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="200" y="200" width="540" height="660" as="geometry"/>
        </mxCell>

        <mxCell id="prfaas_compute" value="Prefill Nodes (homogeneous, compute-dense)&#xa;e.g. 32× H200 (4 instances × 8 GPU)&#xa;Effective throughput = min(compute, egress BW)" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="240" width="500" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="prfaas_net" value="Intra-cluster RDMA (TP / EP collectives)&#xa;800 Gbps per node, latency-sensitive" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="460" width="500" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="prfaas_stor" value="Hybrid Prefix Cache Pool (intra-cluster only, prefix-cache blocks)&#xa;+ Transfer-cache blocks (egress staging, discarded after PD-D ack)" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="220" y="680" width="500" height="80" as="geometry"/>
        </mxCell>

        <!-- Local PD Cluster column -->
        <mxCell id="pd_box" value="Local PD Cluster (Short Request l ≤ t + ALL Decode)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="640" height="660" as="geometry"/>
        </mxCell>

        <mxCell id="pd_p" value="PD-P (prefill) Nodes (N_p)" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="240" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="pd_d" value="PD-D (decode) Nodes (N_d)&#xa;sole consumer of KVCache from both PrfaaS &amp; PD-P" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1230" y="240" width="280" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="pd_ratio" value="N_p / N_d adjustable on the fly (long-term scheduler reassigns nodes between roles)" style="rounded=0;whiteSpace=wrap;fillColor=none;strokeColor=#d6b656;dashed=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="920" y="340" width="600" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="pd_net" value="Intra-cluster RDMA (PD KV transfer + collectives)&#xa;800 Gbps per node" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="460" width="600" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="pd_stor" value="Hybrid Prefix Cache Pool (decode-side reuse)&#xa;+ Receives transfer-cache blocks from PrfaaS via Ethernet" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#28a745;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="920" y="680" width="600" height="80" as="geometry"/>
        </mxCell>

        <!-- Cross-cluster Ethernet bridge -->
        <mxCell id="eth" value="Cross-DC Ethernet (commodity, ~100 Gbps VPC)&#xa;multi-connection TCP + congestion monitoring + layer-wise prefill pipelining" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="475" width="180" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="eth_l" style="endArrow=classic;html=1;strokeWidth=2;startArrow=classic;" edge="1" parent="1" source="prfaas_net" target="eth"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="eth_r" style="endArrow=classic;html=1;strokeWidth=2;startArrow=classic;" edge="1" parent="1" source="eth" target="pd_net"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Global KVCache Manager (spans both columns) -->
        <mxCell id="gkm" value="Global KVCache Manager — tracks (block_id → cluster, node, slot) for prefix matching across PrfaaS + all PD clusters; triggers cache rebalancing on hotspots" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="200" y="800" width="1340" height="60" as="geometry"/>
        </mxCell>

        <!-- Routing arrows from router -->
        <mxCell id="route_long" value="l &gt; t (long uncached prefill)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#1e88e5;fontSize=10;fontStyle=1;" edge="1" parent="1" source="router" target="prfaas_compute"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="route_short" value="l ≤ t (short prefill)" style="endArrow=classic;html=1;strokeWidth=2;strokeColor=#fb8c00;fontSize=10;fontStyle=1;" edge="1" parent="1" source="router" target="pd_p"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- Page 3: Hybrid Prefix Cache Pool internals -->
  <diagram id="page3" name="3. Hybrid Prefix Cache Pool">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Hybrid Prefix Cache Pool — heterogeneous KV (linear req-state vs full-attn block) sharing one block pool, two block roles (prefix vs transfer)" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="30" as="geometry"/>
        </mxCell>

        <!-- TOP: KVCache Groups -->
        <mxCell id="grp_lin" value="KVCache Group A — Linear-attention layers&#xa;(KDA / SWA / Lightning / GDN)&#xa;• Recurrent state, fixed size&#xa;• REQUEST-LEVEL granularity&#xa;• Reusable only on EXACT length match" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="450" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="grp_full" value="KVCache Group B — Full-attention layers&#xa;(MLA / GQA, the &quot;1&quot; in 3:1 / 5:1 / 7:1 hybrid stacks)&#xa;• Linear in seq-length, paged blocks&#xa;• BLOCK-LEVEL granularity&#xa;• Supports partial PREFIX matching" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="600" y="100" width="450" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="grp_groups" value="Group 0 / 1 / 2&#xa;(per linear-attn type)" style="rounded=0;whiteSpace=wrap;fillColor=none;strokeColor=#6c8ebf;dashed=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="120" y="280" width="370" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="grp_group3" value="Group 3 (full-attn KV)" style="rounded=0;whiteSpace=wrap;fillColor=none;strokeColor=#d6b656;dashed=1;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="640" y="280" width="370" height="40" as="geometry"/>
        </mxCell>

        <!-- BOTTOM: Unified Block Pool -->
        <mxCell id="pool" value="Unified Hybrid Block Pool (aligned block sizes — every group allocates/frees from the SAME backing pool)" style="rounded=1;whiteSpace=wrap;fillColor=#e6f5e6;strokeColor=#28a745;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="380" width="1340" height="240" as="geometry"/>
        </mxCell>

        <mxCell id="pc_box" value="Prefix-Cache Blocks&#xa;• reusable across requests&#xa;• MUST be fully populated&#xa;• block-aligned, intra-cluster only&#xa;• evictable by LRU/length policies" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="120" y="430" width="380" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="tc_box" value="Transfer-Cache Blocks&#xa;• tail-of-prefill output&#xa;• cross-cluster transport over Ethernet&#xa;• ANY length (not block-aligned)&#xa;• DISCARDED on transfer completion" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="540" y="430" width="380" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="free_box" value="Free Blocks&#xa;available for next allocation&#xa;(any group)" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="960" y="430" width="380" height="170" as="geometry"/>
        </mxCell>

        <!-- Edges from groups to pool -->
        <mxCell id="ea1" style="endArrow=classic;html=1;dashed=1;strokeColor=#6c8ebf;" edge="1" parent="1" source="grp_lin" target="pool"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ea2" style="endArrow=classic;html=1;dashed=1;strokeColor=#d6b656;" edge="1" parent="1" source="grp_full" target="pool"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Bottom note: cross-cluster vs intra-cluster behavior -->
        <mxCell id="note" value="Why split prefix vs transfer? Cross-cluster cache transfer is expensive — only worth it for the request's INCREMENTAL output (transfer-cache).&#xa;Long-term reuse (prefix-cache) stays cluster-local; the global manager redirects requests to the cluster that already holds the prefix when possible.&#xa;When BW is abundant, scheduler may copy a prefix block across clusters (rare path); when BW is scarce, prefix matching is evaluated INDEPENDENTLY per cluster." style="rounded=0;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="650" width="1340" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- Page 4: Throughput Model & Converging Pipeline -->
  <diagram id="page4" name="4. Throughput Model">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Converging pipeline: PrfaaS + PD-P → PD-D — end-to-end Λ_max bounded by slowest stage (per Eq. 6)" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1620" height="30" as="geometry"/>
        </mxCell>

        <!-- Request source -->
        <mxCell id="src" value="Requests Λ&#xa;(arrival rate)&#xa;L ~ truncated log-normal&#xa;μ=9.9, σ=1.0, [128, 128K]" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="220" height="120" as="geometry"/>
        </mxCell>

        <!-- Routing split -->
        <mxCell id="split" value="Length-based router&#xa;split by t" style="rhombus;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="300" width="220" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="es" style="endArrow=classic;html=1;" edge="1" parent="1" source="src" target="split"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- PrfaaS branch (top) -->
        <mxCell id="prfaas" value="PrfaaS prefill (top branch)&#xa;fraction p = P(L &gt; t)&#xa;l_long = E[L | L &gt; t]&#xa;&#xa;Θ_prfaas = min( N_prfaas / T_pre(l_long),&#xa;                     B_out / S_kv(l_long) )&#xa;&#xa;case study: 4 instances (32×H200), B_out=100Gbps&#xa;Θ_prfaas = 1.61 req/s (compute-bound, 13Gbps egress)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="640" y="120" width="420" height="180" as="geometry"/>
        </mxCell>

        <!-- PD-P branch (bottom) -->
        <mxCell id="pd_p" value="PD-P prefill (bottom branch)&#xa;fraction 1-p&#xa;l_short = E[L | L ≤ t]&#xa;&#xa;Θ_pd-p = N_p / T_pre(l_short)&#xa;(intra-cluster RDMA never bottlenecks)&#xa;&#xa;case study: N_p=3 (24×H20)&#xa;Θ_pd-p = 1.64 req/s" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="640" y="400" width="420" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="ep1" value="p, Ethernet, transfer-cache" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#1e88e5;fontSize=10;fontStyle=1;" edge="1" parent="1" source="split" target="prfaas"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ep2" value="1-p, RDMA local" style="endArrow=classic;html=1;strokeWidth=3;strokeColor=#fb8c00;fontSize=10;fontStyle=1;" edge="1" parent="1" source="split" target="pd_p"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Convergence into PD-D -->
        <mxCell id="merge" value="Merge: KV streams converge at decode" style="ellipse;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1140" y="300" width="200" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="em1" style="endArrow=classic;html=1;" edge="1" parent="1" source="prfaas" target="merge"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="em2" style="endArrow=classic;html=1;" edge="1" parent="1" source="pd_p" target="merge"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- PD-D -->
        <mxCell id="pd_d" value="PD-D decode (consumer)&#xa;&#xa;Θ_pd-d = N_d · BS_max / (T_dec · L_out)&#xa;(BS_max, T_dec set by SLO)&#xa;&#xa;case study: N_d=5 (40×H20), L_out=1024&#xa;Θ_pd-d = 3.91 req/s" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1410" y="220" width="260" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="ed1" style="endArrow=classic;html=1;strokeWidth=3;" edge="1" parent="1" source="merge" target="pd_d"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- End-to-end equation -->
        <mxCell id="eq" value="Λ_max = min( Θ_prfaas / p,  Θ_pd-p / (1-p),  Θ_pd-d )    [Eq. 6]&#xa;&#xa;Optimum (Eq. 7 + Eq. 8): both upstream branches saturate together AND match downstream consumer&#xa;    Θ_prfaas / p = Θ_pd-p / (1-p)              ← split balance (tunes t)&#xa;    Θ_prfaas + Θ_pd-p = Θ_pd-d                  ← producer / consumer balance (tunes N_p / N_d)&#xa;&#xa;case study: t = 19.4K (≈50% of requests), N_prfaas=4, N_p=3, N_d=5  →  Λ_max = 3.24 req/s (1.54× homogeneous PD)" style="rounded=1;whiteSpace=wrap;fillColor=#fff9e6;strokeColor=#d6b656;fontSize=11;align=left;verticalAlign=middle;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="1620" height="200" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- Page 5: Dual-Timescale Scheduling -->
  <diagram id="page5" name="5. Dual-Timescale Scheduling">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Dual-timescale scheduler — short-term cache+BW-aware routing  ‖  long-term traffic-driven re-allocation" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1400" height="30" as="geometry"/>
        </mxCell>

        <!-- Top: short-term -->
        <mxCell id="st_box" value="Short-term: per-request routing (ms-scale)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="1420" height="380" as="geometry"/>
        </mxCell>

        <mxCell id="st_in" value="Incoming request:&#xa;l_total = total prompt length&#xa;l_prfaas = matched prefix in PrfaaS cluster&#xa;l_pd = matched prefix in PD cluster" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="140" width="320" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="st_bw" value="Probe egress BW utilization U_BW&#xa;and PrfaaS queue depth Q" style="rhombus;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="450" y="160" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="se1" style="endArrow=classic;html=1;" edge="1" parent="1" source="st_in" target="st_bw"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- BW scarce branch -->
        <mxCell id="st_scarce" value="BW SCARCE: evaluate caches independently&#xa;l_inc_pd = l_total − l_pd&#xa;if l_inc_pd ≤ t  → PD-P (local, no cross-DC traffic)&#xa;else                → PrfaaS (only PrfaaS prefix used)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="740" y="100" width="380" height="140" as="geometry"/>
        </mxCell>

        <!-- BW abundant branch -->
        <mxCell id="st_abund" value="BW ABUNDANT: pick the LONGEST cache anywhere&#xa;l_prefix = max(l_prfaas, l_pd)&#xa;l_inc = l_total − l_prefix&#xa;if l_inc ≤ t  → PD-P (with optional cross-DC prefix copy)&#xa;else              → PrfaaS (with optional cross-DC prefix copy)" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1140" y="100" width="320" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="se_sc" value="U_BW &gt; threshold (or queueing)" style="endArrow=classic;html=1;strokeColor=#b85450;" edge="1" parent="1" source="st_bw" target="st_scarce"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se_ab" value="U_BW low" style="endArrow=classic;html=1;strokeColor=#28a745;" edge="1" parent="1" source="st_bw" target="st_abund"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Threshold update sub-loop -->
        <mxCell id="st_thr" value="Periodic re-profile of t&#xa;• re-measure compute &amp; egress capacity&#xa;• re-fit incremental-length distribution after prefix matching&#xa;• re-solve grid search to set NEW threshold t" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="300" width="500" height="140" as="geometry"/>
        </mxCell>

        <mxCell id="st_route" value="Final route &amp; admit:&#xa;• If PrfaaS: prefill + transfer-cache → cross-DC Ethernet → PD-D&#xa;• If PD-P: prefill + KVCache via intra-cluster RDMA → PD-D&#xa;• Update PrfaaS queue + BW counters" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="640" y="300" width="820" height="140" as="geometry"/>
        </mxCell>

        <!-- Bottom: long-term -->
        <mxCell id="lt_box" value="Long-term: re-allocate roles inside local PD cluster (minute-to-hour scale)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="490" width="1420" height="350" as="geometry"/>
        </mxCell>

        <mxCell id="lt_mon" value="Monitor stage utilizations + queue depths&#xa;classify binding constraint:&#xa;• if Θ_prfaas + Θ_pd-p ≪ Θ_pd-d → prefill-bound&#xa;• if Θ_prfaas + Θ_pd-p ≫ Θ_pd-d → decode-bound" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="550" width="420" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="lt_decide" value="Decision (every period T):&#xa;• Convert nodes between PD-P ↔ PD-D (ramp drains, then loads new role)&#xa;• Re-solve Eq. 7 + Eq. 8 → new (N_p, N_d)&#xa;• Re-optimize threshold t" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="540" y="550" width="420" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="lt_apply" value="Apply: warm new prefill weights, drain decode batches, push new t to global router; affected nodes briefly remove from rotation" style="rounded=1;whiteSpace=wrap;fillColor=#ffffff;strokeColor=#d6b656;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1000" y="550" width="420" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="le1" style="endArrow=classic;html=1;" edge="1" parent="1" source="lt_mon" target="lt_decide"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="le2" style="endArrow=classic;html=1;" edge="1" parent="1" source="lt_decide" target="lt_apply"><mxGeometry relative="1" as="geometry"/></mxCell>

        <mxCell id="lt_note" value="Note: PrfaaS cluster size N_prfaas is treated as cap-ex constant in this model. Long-term cluster up/down-scaling lives outside this loop (cross-DC capacity planning).&#xa;Only N_p / N_d shifts occur within minutes; t shifts occur at minute or sub-minute cadence." style="rounded=0;whiteSpace=wrap;fillColor=none;strokeColor=#d6b656;dashed=1;fontSize=10;fontStyle=2;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="80" y="730" width="1340" height="100" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
