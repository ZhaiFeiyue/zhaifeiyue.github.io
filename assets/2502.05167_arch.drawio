  <!-- ============================================================== -->
  <!-- Page 1: NoLiMa task overview - latent association reasoning    -->
  <!-- ============================================================== -->
  <diagram id="page1" name="1. NoLiMa Task Overview">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="NoLiMa — Long-Context Eval Beyond Literal Matching: Question and Needle have ZERO surface-level overlap; model must traverse a latent association link" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1660" height="30" as="geometry"/>
        </mxCell>

        <!-- Haystack column -->
        <mxCell id="haystack_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="380" height="900" as="geometry"/>
        </mxCell>
        <mxCell id="haystack_lbl" value="Haystack &#xa;(60K+ tokens, randomly concatenated &#xa;snippets from 10 open-license books, &#xa;each snippet &lt; 250 tokens)" style="text;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="360" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="hay_top" value="...irrelevant book text...&#xa;...irrelevant book text...&#xa;...irrelevant book text..." style="rounded=0;whiteSpace=wrap;fillColor=#eeeeee;strokeColor=#999999;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="340" height="200" as="geometry"/>
        </mxCell>

        <!-- The needle -->
        <mxCell id="needle_box" value="NEEDLE (1 sentence)&#xa;&#xa;Actually, [CHAR=Yuki] lives next&#xa;to the W_n = Semper Opera House.&#xa;&#xa;(placed at depth d, controlled)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="340" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="hay_bot" value="...irrelevant book text...&#xa;...irrelevant book text...&#xa;(filtered: no W_q, no answer leak)" style="rounded=0;whiteSpace=wrap;fillColor=#eeeeee;strokeColor=#999999;fontSize=10;align=left;" vertex="1" parent="1">
          <mxGeometry x="60" y="520" width="340" height="420" as="geometry"/>
        </mxCell>

        <!-- Question column -->
        <mxCell id="q_lbl" value="Question (W_q in question)" style="text;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="70" width="320" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="q_one" value="ONE-HOP&#xa;&#xa;W_q = &quot;Dresden&quot;&#xa;&#xa;&quot;Which character has been&#xa;to Dresden?&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="480" y="120" width="320" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="q_two" value="TWO-HOP&#xa;&#xa;W_q = &quot;Saxony&quot;  (state)&#xa;&#xa;&quot;Which character has been&#xa;to the state of Saxony?&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="480" y="270" width="320" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="q_constr" value="Critical constraint:&#xa;ROUGE-L precision(question, needle) ≈ 0.067&#xa;(vanilla NIAH ≈ 0.855)&#xa;⇒ NO literal/lexical overlap, only semantic link" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=left;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="480" y="420" width="320" height="100" as="geometry"/>
        </mxCell>

        <!-- Latent association graph -->
        <mxCell id="assoc_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="60" width="800" height="500" as="geometry"/>
        </mxCell>
        <mxCell id="assoc_lbl" value="Latent association (lives in model's parametric world knowledge)" style="text;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="70" width="780" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="char" value="CHAR&#xa;&quot;Yuki&quot;&#xa;(answer)" style="ellipse;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="200" width="140" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="wn" value="W_n&#xa;&quot;Semper Opera House&quot;&#xa;(needle keyword)" style="ellipse;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1120" y="200" width="160" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="wq1" value="W_q (1-hop)&#xa;&quot;Dresden&quot;&#xa;(city)" style="ellipse;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1360" y="120" width="160" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="wq2" value="W_q (2-hop)&#xa;&quot;Saxony&quot;&#xa;(state)" style="ellipse;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1360" y="280" width="160" height="100" as="geometry"/>
        </mxCell>

        <!-- Edges -->
        <mxCell id="e1" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;strokeColor=#666666;" edge="1" parent="1" source="char" target="wn">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e1_lbl" value="explicitly stated&#xa;in needle text" style="text;fontSize=10;align=center;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="1040" y="180" width="100" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="e2" style="endArrow=classic;html=1;exitX=1;exitY=0.3;entryX=0;entryY=0.5;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="wn" target="wq1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e2_lbl" value="latent hop 1&#xa;(world knowledge:&#xa;opera is in Dresden)" style="text;fontSize=10;align=center;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1280" y="120" width="120" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="e3" style="endArrow=classic;html=1;exitX=1;exitY=0.7;entryX=0;entryY=0.5;strokeColor=#b85450;dashed=1;" edge="1" parent="1" source="wn" target="wq2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e3_lbl" value="latent hop 1+2&#xa;(opera→Dresden→Saxony)" style="text;fontSize=10;align=center;fontStyle=2;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="1280" y="350" width="120" height="40" as="geometry"/>
        </mxCell>

        <!-- Causal attention narrative -->
        <mxCell id="attn_box" value="What the LLM has to do (causal attention only):&#xa;1. From query token (W_q in question), attend back to SOME token in haystack carrying W_n.&#xa;2. Resolve the latent link W_q ↔ W_n via parametric knowledge — there is NO surface match to lock onto.&#xa;3. From W_n, backtrace to the [CHAR] token mentioned earlier in the same needle sentence.&#xa;Failure mode: at long context, attention probability over the relevant W_n token is diluted; without literal matches as &#xa;a &quot;magnet&quot;, the relevance signal drops below noise floor of 60K+ irrelevant tokens." style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="880" y="600" width="780" height="180" as="geometry"/>
        </mxCell>

        <mxCell id="results_box" value="Headline results (Table 3):&#xa;• 13/13 models with claimed context ≥ 128K have effective length ≤ 8K on NoLiMa (most ≤ 2K).&#xa;• 11/13 fall below 50% of base score by 32K. Even GPT-4o drops 99.3% → 69.7% at 32K.&#xa;• Adding ONE distractor sentence containing W_q (irrelevant) collapses GPT-4o eff. length: 8K → 1K." style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="880" y="800" width="780" height="140" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ============================================================== -->
  <!-- Page 2: Filtering pipeline (haystack construction)              -->
  <!-- ============================================================== -->
  <diagram id="page2" name="2. Haystack Filtering Pipeline">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="NoLiMa Haystack Filtering Pipeline (Section 3.1) — eliminate (1) lexical/semantic distractors of W_q and (2) text spans that could serve as plausible alternative answers" style="text;align=left;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1660" height="30" as="geometry"/>
        </mxCell>

        <!-- Stage 1: distractor filter -->
        <mxCell id="s1_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff5f5;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="780" height="380" as="geometry"/>
        </mxCell>
        <mxCell id="s1_lbl" value="Stage 1: Distractor Word Filtering&#xa;(per-question keyword W_q)" style="text;align=center;fontSize=12;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="760" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="b1" value="10 open-license books&#xa;each ≥ 50K tokens" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b2" value="Embed every word with&#xa;Contriever (Izacard 2022)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="300" y="120" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b3" value="Top-20 by dot-product&#xa;similarity to each W_q" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="120" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b4" value="Manual review by author —&#xa;flag words with substring match&#xa;or high semantic match to W_q" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="280" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b5" value="Remove ALL sentences&#xa;containing flagged words" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="220" width="200" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="b6" value="Distractor-clean&#xa;haystack pool" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="220" width="160" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="s1_note" value="Why this matters: any haystack token sharing surface form with W_q would &#xa;give the model a free attention magnet, defeating the &quot;no literal match&quot; design.&#xa;Section 4.4.4 measures this effect explicitly." style="text;fontSize=10;align=left;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="60" y="310" width="720" height="60" as="geometry"/>
        </mxCell>

        <!-- arrows stage 1 -->
        <mxCell id="se1" style="endArrow=classic;html=1;" edge="1" parent="1" source="b1" target="b2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se2" style="endArrow=classic;html=1;" edge="1" parent="1" source="b2" target="b3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="b3" target="b4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se4" style="endArrow=classic;html=1;" edge="1" parent="1" source="b4" target="b5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="se5" style="endArrow=classic;html=1;" edge="1" parent="1" source="b5" target="b6"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Stage 2: answer leak filter -->
        <mxCell id="s2_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff8e1;strokeColor=#d79b00;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="860" y="60" width="800" height="780" as="geometry"/>
        </mxCell>
        <mxCell id="s2_lbl" value="Stage 2: Plausible-Alternative-Answer Filtering (semi-automatic loop)" style="text;align=center;fontSize=12;fontStyle=1;fontColor=#d79b00;" vertex="1" parent="1">
          <mxGeometry x="870" y="70" width="780" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="c1" value="Distractor-clean haystack" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="120" width="200" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="c2" value="Sliding window&#xa;chunk size 1000 chars (~250 tok)&#xa;stride 800 chars" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1180" y="120" width="240" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="c3" value="For each (chunk, question) pair:&#xa;prompt Llama 3.3 70B-Instruct&#xa;with few-shot examples" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="900" y="220" width="320" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="c4" value="Output:&#xa;&quot;N/A&quot;  OR  candidate-answer span" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1280" y="220" width="320" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="c5" value="Author manually reviews&#xa;every flagged span;&#xa;decides remove vs keep" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1080" y="320" width="320" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="c6" value="Loop until &quot;no further removals&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="430" width="320" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="c7" value="Final book = answer-leak-free,&#xa;distractor-free, ready for haystack assembly" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1080" y="510" width="320" height="60" as="geometry"/>
        </mxCell>

        <!-- arrows stage 2 -->
        <mxCell id="ce1" style="endArrow=classic;html=1;" edge="1" parent="1" source="c1" target="c2"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c2" target="c4"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c1" target="c3"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce4" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c3" target="c5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce5" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="c4" target="c5"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce6" style="endArrow=classic;html=1;" edge="1" parent="1" source="c5" target="c6"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce7" style="endArrow=classic;html=1;" edge="1" parent="1" source="c6" target="c7"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce8" style="endArrow=classic;html=1;dashed=1;exitX=0;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="c6" target="c1"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ce8_lbl" value="re-scan&#xa;cleaned text" style="text;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="900" y="380" width="80" height="30" as="geometry"/>
        </mxCell>

        <!-- Validation -->
        <mxCell id="val_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#e8f5e9;strokeColor=#28a745;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="600" width="720" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="val_lbl" value="Filter validity check" style="text;align=center;fontSize=12;fontStyle=1;fontColor=#28a745;" vertex="1" parent="1">
          <mxGeometry x="910" y="610" width="700" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="v1" value="Insert each needle into 100 random chunks. Ask Llama 3.3 70B&#xa;the question. Check whether it can identify the conflict.&#xa;&#xa;Result: 99.8% accuracy ⇒ filter LLM understands the task &amp;&#xa;has the world knowledge to spot a true alternative answer." style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="930" y="650" width="660" height="140" as="geometry"/>
        </mxCell>

        <!-- Final assembly note -->
        <mxCell id="final_note" value="Haystack assembly (Section 4.1):&#xa;• Iteratively pick a random book &amp; extract a continuous snippet &lt; 250 tokens, append until total ≥ 2K lines (≥ 60K tokens). &#xa;• Memorisation defence: snippet-shuffling breaks any large contiguous passage the model could recall.&#xa;• Per context length L, place each needle 26 times at equal-spaced depths × 5 random haystacks × 58 needle-question pairs = 7,540 tests." style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="40" y="500" width="780" height="160" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ============================================================== -->
  <!-- Page 3: Default vs Inverted needle order; 1-hop vs 2-hop       -->
  <!-- ============================================================== -->
  <diagram id="page3" name="3. Needle Variants &amp; Causal-Attention Failure">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Why Inverted &amp; Two-hop Needles Are Harder — a causal-attention story" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1660" height="30" as="geometry"/>
        </mxCell>

        <!-- Default panel -->
        <mxCell id="def_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#e8f5e9;strokeColor=#28a745;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="800" height="450" as="geometry"/>
        </mxCell>
        <mxCell id="def_lbl" value="Default order:  &quot;... [CHAR=Yuki] lives next to the W_n=Semper Opera House.&quot;" style="text;align=center;fontSize=12;fontStyle=1;fontColor=#28a745;" vertex="1" parent="1">
          <mxGeometry x="50" y="70" width="780" height="30" as="geometry"/>
        </mxCell>

        <!-- token strip -->
        <mxCell id="d_chr" value="[CHAR]&#xa;Yuki" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="d_pred" value="lives next to the" style="rounded=1;whiteSpace=wrap;fillColor=#eeeeee;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="200" y="120" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="d_wn" value="W_n&#xa;Semper Opera House" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="120" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="d_haystack" value="...60K-token haystack...&#xa;Question prompt at end:&#xa;&quot;Which char has been to W_q=Dresden?&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="640" y="120" width="180" height="60" as="geometry"/>
        </mxCell>

        <!-- causal attention path -->
        <mxCell id="d_path" value="Causal attention path (right→left):&#xa;1. W_q=&quot;Dresden&quot; in query attends back &amp; finds W_n=&quot;Semper Opera House&quot;&#xa;    via latent association  (Dresden ↔ opera in parametric KB)&#xa;2. From W_n token, attend back to nearby [CHAR] token in same needle sentence&#xa;3. Output [CHAR] = &quot;Yuki&quot;&#xa;⇒ TWO causal hops, both well-supported — works up to large L." style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="80" y="220" width="740" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="d_score" value="Empirical (Fig 2b, Llama 3.3 70B, 32K): default ≈ 0.74&#xa;GPT-4o default ≈ 0.81 — both above inverted by ~10 pp" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="740" height="80" as="geometry"/>
        </mxCell>

        <!-- Inverted panel -->
        <mxCell id="inv_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=#fff5f5;strokeColor=#b85450;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="60" width="800" height="450" as="geometry"/>
        </mxCell>
        <mxCell id="inv_lbl" value="Inverted order:  &quot;W_n=Semper Opera House is next to where [CHAR=Yuki] lives.&quot;" style="text;align=center;fontSize=12;fontStyle=1;fontColor=#b85450;" vertex="1" parent="1">
          <mxGeometry x="880" y="70" width="780" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="i_wn" value="W_n&#xa;Semper Opera House" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="120" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="i_pred" value="is next to where" style="rounded=1;whiteSpace=wrap;fillColor=#eeeeee;strokeColor=#999999;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1120" y="120" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="i_chr" value="[CHAR]&#xa;Yuki" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1340" y="120" width="100" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="i_haystack" value="...60K-token haystack...&#xa;Question:&#xa;&quot;Which char has been to W_q=Dresden?&quot;" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="1460" y="120" width="180" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="i_path" value="Causal attention path (right→left):&#xa;1. W_q=&quot;Dresden&quot; in query attends back to W_n=&quot;Semper Opera House&quot; — OK (latent link).&#xa;2. From W_n token, look BACKWARD for an answer ⇒ but [CHAR] is to the RIGHT&#xa;    of W_n in the sentence. The W_n token cannot see [CHAR] under causal masking.&#xa;3. Model must instead attend FORWARD-from-[CHAR] to recall its predecessors —&#xa;    this is essentially the reverse of induction-head behaviour and is&#xa;    much weaker, especially at long L." style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="900" y="220" width="740" height="160" as="geometry"/>
        </mxCell>

        <mxCell id="i_score" value="Empirical (Fig 2b, 32K): inverted ≈ 0.51 (Llama 3.3 70B), 0.66 (GPT-4o)&#xa;⇒ Performance gap to default widens with L — confirms causal-attention bottleneck." style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="900" y="400" width="740" height="80" as="geometry"/>
        </mxCell>

        <!-- 1-hop vs 2-hop -->
        <mxCell id="hop_title" value="One-hop vs Two-hop reasoning load" style="text;align=left;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="900" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="oh_box" value="ONE-HOP&#xa;&#xa;W_q=&quot;Dresden&quot;&#xa;Latent link:  &quot;Semper Opera House&quot; ↔ &quot;Dresden&quot;&#xa;⇒ single fact retrieval from KB at the same time as recall.&#xa;&#xa;Llama 3.3 70B (32K, no CoT, Tab 11): 56.2%&#xa;GPT-4o (32K):   79.8%" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="800" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="th_box" value="TWO-HOP&#xa;&#xa;W_q=&quot;Saxony&quot;&#xa;Latent chain:  &quot;Semper Opera House&quot; → &quot;Dresden&quot; → &quot;Saxony&quot;&#xa;⇒ multi-step KB traversal happening *inside* attention&#xa;⇒ weaker per-step probability ⇒ noise floor reached earlier.&#xa;&#xa;Llama 3.3 70B (32K, no CoT, Tab 12): 25.9%&#xa;GPT-4o (32K):   57.4%&#xa;&#xa;Effect (Fig 2a): 1-hop vs 2-hop gap WIDENS as L grows.&#xa;Effect (Fig 3b): full-sweep performance distribution flattens DOWN to&#xa;~0 at every depth, not just middle. Lost-in-the-middle disappears&#xa;because the whole curve drops." style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="870" y="580" width="800" height="350" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

  <!-- ============================================================== -->
  <!-- Page 4: Evaluation harness + Placement protocols              -->
  <!-- ============================================================== -->
  <diagram id="page4" name="4. Eval Harness &amp; Placement Protocols">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="950" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="NoLiMa Evaluation Harness — placement, scoring, and the &quot;effective length&quot; metric" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="20" y="10" width="1660" height="30" as="geometry"/>
        </mxCell>

        <!-- Pipeline -->
        <mxCell id="ip" value="Inputs:&#xa;• needle_set.json (58 q-needle pairs)&#xa;• haystack/rand_shuffle/*.txt (10 books, distractor- &amp; answer-leak-filtered)&#xa;• model_config.json (engine: vllm | openai | gemini | anthropic | bedrock)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="500" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="bh" value="BookHaystack.generate_w_needle_placement(...)&#xa;• Encode book to tokens; record positions where token contains '\n' as valid insert points.&#xa;• For target context_length L and depth d ∈ [0, 1]:&#xa;     start = nearest_newline_before(d·L)&#xa;     end   = start + L&#xa;• Insert needle at depth d, optionally insert distractor sentence.&#xa;• Returns dict{ text, static_depth, token_depth, depth, context_length_wo_needle }" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="780" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="run" value="run_tests.py × 8 context lengths {250, 500, 1K, 2K, 4K, 8K, 16K, 32K}&#xa;For each L: 26 placements × 5 haystacks × 58 q-needle pairs = 7,540 tests" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="1340" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="prompt" value="Task prompt (Appendix C):&#xa;&quot;You will answer a question based on the following book snippet:&#xa;{haystack with embedded needle}&#xa;Use the information provided in the book snippet to answer the question. Your answer should be short and based on either&#xa;explicitly stated facts or strong, logical inferences.&#xa;Question: {question}&#xa;Return only the final answer with no additional explanation or reasoning.&quot;&#xa;CoT variant: ask for ≤ 3 sentences of reasoning, then final answer on a new line. Hard cap 192 generated tokens.&#xa;Reasoning models (o1/o3/R1): up to 1536 tokens incl. reasoning trace." style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="290" width="800" height="220" as="geometry"/>
        </mxCell>

        <mxCell id="metric" value="Scoring (metric=&quot;contains&quot;):&#xa;• Test passes iff generated answer string contains the gold character name.&#xa;• Per (q, needle, L): average across 5 haystacks.&#xa;• Per L: average across 58 q-needle pairs ⇒ accuracy(L).&#xa;&#xa;Base score:&#xa;• For each (q, needle): take MAX over L ∈ {250, 500, 1K} of mean accuracy.&#xa;• Base score = average across all (q, needle).&#xa;• Threshold = 0.85 × base score.&#xa;&#xa;Effective length:&#xa;• max L such that accuracy(L) ≥ 0.85 × base.&#xa;• Normalised score plots: accuracy(L) / base." style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="880" y="290" width="500" height="320" as="geometry"/>
        </mxCell>

        <!-- Placement protocols -->
        <mxCell id="proto_lbl" value="Two placement protocols for depth analysis" style="text;align=left;fontSize=13;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="540" width="800" height="30" as="geometry"/>
        </mxCell>

        <mxCell id="full_box" value="Full Sweep (the classic NIAH plot)&#xa;• Place needle at depths 0%, 4%, 8%, … 100% of L.&#xa;• Plot accuracy vs depth, separate line per L.&#xa;• Reveals &quot;lost-in-the-middle&quot; (Liu 2024) when applicable.&#xa;• Confound: at large L, the same depth % is a much&#xa;   bigger absolute distance from the question token.&#xa;   Cannot disentangle position-encoding from attention-load." style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="580" width="800" height="200" as="geometry"/>
        </mxCell>

        <mxCell id="last2k_box" value="Last-2K Sweep (NoLiMa novelty, Section 4.4.2)&#xa;• Align needle placements within the LAST 2K tokens of every context length.&#xa;• X-axis: tokens-from-end (0 to 2000). Same physical x-position across all L.&#xa;• Same RoPE relative distance between question &amp; needle for fixed x-position.&#xa;• Therefore, position-encoding decay is HELD CONSTANT.&#xa;• Any drop with growing L must be attributed to the volume of irrelevant&#xa;  tokens the attention has to suppress.&#xa;• Result (Fig 3d, two-hop): plotlines drop nearly uniformly as L grows, even at the same&#xa;  tokens-from-end ⇒ pure attention-overload signature, not a positional bug.&#xa;⇒ This is the cleanest experiment that ISOLATES &quot;long-context attention is&#xa;   fundamentally weaker than short-context attention&quot; from confounders." style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="870" y="580" width="800" height="290" as="geometry"/>
        </mxCell>

        <!-- arrows -->
        <mxCell id="ae1" style="endArrow=classic;html=1;" edge="1" parent="1" source="ip" target="bh"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ae2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="bh" target="run"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ae3" style="endArrow=classic;html=1;exitX=0.5;exitY=1;entryX=0.5;entryY=0;" edge="1" parent="1" source="run" target="prompt"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="ae4" style="endArrow=classic;html=1;exitX=1;exitY=0.5;entryX=0;entryY=0.5;" edge="1" parent="1" source="prompt" target="metric"><mxGeometry relative="1" as="geometry"/></mxCell>

      </root>
    </mxGraphModel>
  </diagram>

</mxfile>
