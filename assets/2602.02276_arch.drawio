• GRMs cross-behaviour
• Toggle (budget / full alternation)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1140" y="440" width="380" height="130" as="geometry"/>
        </mxCell>
        <mxCell id="t_parl" value="PARL — Agent Swarm
λ₁·r_parallel + λ₂·r_finish + r_perf
λ_i annealed to 0
CriticalSteps metric" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="420" width="320" height="110" as="geometry"/>
        </mxCell>
