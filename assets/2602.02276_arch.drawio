        <mxCell id="t_k2" value="K2 Pretrain (text)
15 T tokens · MuonClip + QK-Clip
From Kimi K2 report" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
