<mxfile host="app.diagrams.net">
  <diagram id="page1" name="1. Fleet 4-level Task Hierarchy">
    <mxGraphModel dx="1280" dy="720" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Fleet Task Hierarchy ↔ MI350 Memory Hierarchy (§3.1 Table 3)" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="colH1" value="HW Scope" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="140" height="25" as="geometry" />
        </mxCell>
        <mxCell id="colH2" value="Memory" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="240" y="70" width="140" height="25" as="geometry" />
        </mxCell>
        <mxCell id="colH3" value="Fleet Task" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="400" y="70" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="colH4" value="CUDA/HIP Equivalent" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="600" y="70" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="colH5" value="Typical Operators" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="800" y="70" width="320" height="25" as="geometry" />
        </mxCell>

        <mxCell id="row1_hw" value="SIMD (1 wavefront = 64 threads)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="110" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row1_mem" value="Register file, LDS" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="240" y="110" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row1_task" value="Wavefront-task&#10;1 worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="110" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row1_cuda" value="Wavefront / warp" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="600" y="110" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row1_ops" value="SiLU activation, element-wise multiply, residual add, RoPE" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="800" y="110" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="row2_hw" value="1 CU / workgroup (64–256 threads)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="190" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row2_mem" value="LDS, L1 (TCP)&#10;L2 for data" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="240" y="190" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row2_task" value="CU-task&#10;1 worker" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="190" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row2_cuda" value="Workgroup / thread block" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="600" y="190" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row2_ops" value="Individual attention heads, RMSNorm, argmax / sampling" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="800" y="190" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="row3_hw" value="1 XCD (chiplet) = 32 CUs on MI350&#10;one is scheduler → 31 workers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="140" height="90" as="geometry" />
        </mxCell>
        <mxCell id="row3_mem" value="Private 4 MB L2&#10;(non-coherent across XCDs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="240" y="270" width="140" height="90" as="geometry" />
        </mxCell>
        <mxCell id="row3_task" value="★ Chiplet-task ★&#10;31 workers coop&#10;NEW abstraction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b85450;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="270" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="row3_cuda" value="—&#10;(no direct equivalent;&#10;NVIDIA TB cluster ≠ XCD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="600" y="270" width="180" height="90" as="geometry" />
        </mxCell>
        <mxCell id="row3_ops" value="GEMM partition (one N/8 slice of weight matrix),&#10;cooperative M-major tile traversal over L2-resident tiles" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="800" y="270" width="320" height="90" as="geometry" />
        </mxCell>

        <mxCell id="row4_hw" value="Device = 8 XCDs&#10;(MI350: 256 CUs total)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="370" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row4_mem" value="Global HBM (288 GB)&#10;256 MB Infinity Cache (LLC)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="240" y="370" width="140" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row4_task" value="Device-task&#10;= 8 Chiplet-tasks&#10;with barrier" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="400" y="370" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row4_cuda" value="Grid (kernel launch)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="600" y="370" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="row4_ops" value="Full GEMM (assembled from 8 column slices), split-K GEMM with reduction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="800" y="370" width="320" height="70" as="geometry" />
        </mxCell>

        <mxCell id="keyInsight" value="&lt;b&gt;Key gap (§2):&lt;/b&gt; CUDA/HIP has no abstraction for the Chiplet level — the L2 cache is device-scoped in programming model but physically partitioned on chiplet GPUs (MI300X/MI350: 8 × 4 MB non-coherent; Blackwell: 2 × L2 partitions).&#10;Fleet's &lt;b&gt;Chiplet-task&lt;/b&gt; fills this gap: programmer expresses data partition + tiling + L2 working set per chiplet, enabling cooperative L2 reuse &amp; cheap intra-XCD sync." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;align=left;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="470" width="1040" height="100" as="geometry" />
        </mxCell>

        <mxCell id="note2" value="MI350 numbers: 256 CUs / 8 XCDs = 32 CUs per XCD. Each XCD: 1 scheduler workgroup + 31 worker workgroups.&#10;8 schedulers × 1 CU = 8 CUs (3.1%) sacrificed for control-plane.&#10;Device-task barrier = wait until all 8 Chiplet-tasks report completion via hierarchical 2-level event counter (Figure 5)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="590" width="1040" height="80" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page2" name="2. Persistent Kernel Runtime Layout">
    <mxGraphModel dx="1280" dy="720" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="760" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Fleet Persistent Megakernel Runtime Layout on MI350 (§5.1, §5.2)" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="800" height="30" as="geometry" />
        </mxCell>

        <mxCell id="hbm" value="Global HBM (288 GB): &#10; • Task descriptor queues (populated before kernel launch, read-only during execution)&#10; • Global event counters G[e]  (updated only by last-worker-per-XCD with sc0|sc1)&#10; • Model weights, KV cache, activation tensors" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1080" height="90" as="geometry" />
        </mxCell>

        <mxCell id="llc" value="256 MB Infinity Cache (shared LLC) — victim cache for all 8 L2 partitions" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="560" width="1080" height="40" as="geometry" />
        </mxCell>

        <mxCell id="fabric" value="Infinity Fabric Crossbar — cross-XCD coherence traffic flows here (expensive: buffer_wbl2 + GPU-scope atomics)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="60" y="510" width="1080" height="40" as="geometry" />
        </mxCell>

        <mxCell id="xcd0" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eef7;strokeColor=#6c8ebf;strokeWidth=2;dashed=1" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="520" height="430" as="geometry" />
        </mxCell>
        <mxCell id="xcd0_label" value="XCD 0  (L2 coherent domain, 32 CUs)" style="text;html=1;align=center;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="60" y="76" width="520" height="24" as="geometry" />
        </mxCell>
        <mxCell id="sched0" value="Scheduler&#10;(1 workgroup on 1 CU)&#10;&#10;• reads HW_ID reg&#10;• polls global G[e]&#10;• dispatches tasks to&#10;  per-worker queues&#10;• broadcasts Chiplet-task&#10;  to all 31 workers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="80" y="108" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="workers0" value="Workers W₀ … W₃₀  (31 CUs)&#10;&#10;Each worker holds per-worker task queue in HBM&#10;(naturally cached in local L2 via wave-scope loads).&#10;&#10;Executes: Wavefront-task | CU-task | Chiplet-task body&#10;(MFMA GEMM tiles, attention head, RMSNorm, SiLU ...)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="300" y="108" width="260" height="140" as="geometry" />
        </mxCell>

        <mxCell id="counter0" value="L2-local event counter L[0][e]&#10;(device-scope atomic_add; resolves inside L2; no fence)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="80" y="270" width="480" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l20" value="Private 4 MB L2 (TCC) — cache modifier policy:&#10;• Weights: sc1=1 nt=1 (cache-streaming, reused briefly then evicted)&#10;• Activations: NT=1 (L2 bypass — don't evict weight tiles)&#10;• Intra-XCD sched↔worker: volatile loads (coherent via shared L2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=left;spacingLeft=8;spacingTop=6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="324" width="480" height="90" as="geometry" />
        </mxCell>
        <mxCell id="last0" value="Last-worker check → single buffer_wbl2 fence (L2 → HBM writeback) → flat_atomic_add G[e] with sc0|sc1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="430" width="480" height="50" as="geometry" />
        </mxCell>

        <mxCell id="xcd7" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8eef7;strokeColor=#6c8ebf;strokeWidth=2;dashed=1" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="520" height="430" as="geometry" />
        </mxCell>
        <mxCell id="xcd7_label" value="XCD 7  (symmetric; XCD 1..6 omitted for space)" style="text;html=1;align=center;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="620" y="76" width="520" height="24" as="geometry" />
        </mxCell>
        <mxCell id="sched7" value="Scheduler&#10;(XCD_id=7)&#10;polls G[e] ≥ need" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=10;fontStyle=1;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="640" y="108" width="200" height="140" as="geometry" />
        </mxCell>
        <mxCell id="workers7" value="Workers W₂₁₇ … W₂₄₇  (31 CUs)&#10;&#10;Consume their assigned Chiplet-task slice:&#10;  output cols [7 × N/8, 8 × N/8)&#10;M-major windowed traversal →&#10;R = min(31, m_tiles) workers share each weight tile" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="860" y="108" width="260" height="140" as="geometry" />
        </mxCell>
        <mxCell id="counter7" value="L2-local event counter L[7][e]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=10;align=center;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="640" y="270" width="480" height="40" as="geometry" />
        </mxCell>
        <mxCell id="l27" value="Private 4 MB L2 — same cache modifier policy as XCD 0" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=10;align=center" vertex="1" parent="1">
          <mxGeometry x="640" y="324" width="480" height="90" as="geometry" />
        </mxCell>
        <mxCell id="last7" value="Single buffer_wbl2 + GPU-scope atomic_add G[e]" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=10;align=center;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="640" y="430" width="480" height="50" as="geometry" />
        </mxCell>

        <mxCell id="edge1" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2" edge="1" parent="1" source="last0" target="fabric">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge2" style="endArrow=classic;html=1;strokeColor=#b85450;strokeWidth=2" edge="1" parent="1" source="last7" target="fabric">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge3" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2" edge="1" parent="1" source="fabric" target="llc">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="edge4" style="endArrow=classic;html=1;strokeColor=#82b366;strokeWidth=2" edge="1" parent="1" source="llc" target="hbm">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page3" name="3. Hierarchical 2-level Sync">
    <mxGraphModel dx="1280" dy="720" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Hierarchical 2-level Event Synchronization — turns 248 global fences into 8 (§5.2)" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1000" height="30" as="geometry" />
        </mxCell>

        <mxCell id="flatTitle" value="(a) Flat / naïve: every worker issues GPU-scope atomic + fence" style="text;html=1;align=center;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="520" height="24" as="geometry" />
        </mxCell>
        <mxCell id="flatWorkers" value="248 workers (31 per XCD × 8) each execute:&#10;  __threadfence() + atomic_add(G[e], 1) with sc0|sc1&#10;→ 248 cross-chiplet fences per event → L2 dirty-line writebacks scale with per-worker traffic → long stalls on Infinity Fabric" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="520" height="120" as="geometry" />
        </mxCell>
        <mxCell id="flatG" value="Global G[e] on HBM&#10;(contended: 248 writers)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b85450;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="200" y="230" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="flatCost" value="Total fences / event = 248&#10;Expected stall ~ 248 × t_wbl2 + contention" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="60" y="300" width="520" height="50" as="geometry" />
        </mxCell>

        <mxCell id="hierTitle" value="(b) Fleet hierarchical: 2-level counter, fence only on last-worker-per-XCD" style="text;html=1;align=center;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="520" height="24" as="geometry" />
        </mxCell>
        <mxCell id="hierL1" value="Level 1: intra-XCD (L2-local, no fence)&#10;Each worker: atomic_add(L[xcd_id][e], 1)&#10;→ resolves in local L2 only, no Infinity Fabric traffic" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="620" y="100" width="520" height="80" as="geometry" />
        </mxCell>
        <mxCell id="hierLast" value="Last-worker test: if L[xcd_id][e] == T then&#10;   issue buffer_wbl2 (1 L2→HBM writeback)&#10;   flat_atomic_add(G[e], 1) with sc0|sc1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;spacingTop=6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="620" y="190" width="520" height="70" as="geometry" />
        </mxCell>
        <mxCell id="hierG" value="Global G[e] on HBM&#10;(only 8 writers, one per XCD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="760" y="270" width="240" height="50" as="geometry" />
        </mxCell>
        <mxCell id="hierCost" value="Total fences / event = 8&#10;→ 31× reduction per event (W = 31 workers/XCD)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1;align=center" vertex="1" parent="1">
          <mxGeometry x="620" y="340" width="520" height="50" as="geometry" />
        </mxCell>

        <mxCell id="decomposeTitle" value="Decomposition rationale (paper §5.2)" style="text;html=1;align=center;fontStyle=1;fontSize=13" vertex="1" parent="1">
          <mxGeometry x="100" y="410" width="1000" height="24" as="geometry" />
        </mxCell>
        <mxCell id="decompose1" value="① Task queue — read-only. No sync needed (populated pre-launch)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="100" y="440" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="decompose2" value="② Scheduler → worker dispatch — device-scope atomic, but writer and readers all on same XCD → resolves in local L2 without fabric traffic." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="100" y="475" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="decompose3" value="③ Worker → worker intra-Chiplet-task — device-scope atomic on L[xcd][e] counter; all participants share L2 partition, so no cross-XCD coherence and no fence required." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="100" y="510" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="decompose4" value="④ XCD → global — only one worker per XCD makes the expensive trip: 1 buffer_wbl2 + 1 GPU-scope atomic. Amortizes fabric cost across the whole Chiplet-task." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="555" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="decompose5" value="For wavefront-task and CU-task (1 worker), two-level counting is skipped — the single worker directly does the global atomic. Fleet's linear events (8 Chiplet-tasks/event for a dense GEMM) → 8 fences/event exactly." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="100" y="610" width="1000" height="50" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page4" name="4. Cooperative M-major Tiling">
    <mxGraphModel dx="1280" dy="720" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="720" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Cooperative M-major Weight Tiling = L2 Hit Rate Model (§4.1, §6.4)" style="text;html=1;align=center;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="100" y="20" width="1000" height="30" as="geometry" />
        </mxCell>

        <mxCell id="setup" value="&lt;b&gt;Setup:&lt;/b&gt; One Chiplet-task processes [M, K] × [K, N/8] = [M, N/8] sub-GEMM on one XCD.&#10;Output tile shape is [T_M, T_N] (e.g. 16 × 256). Along M (batch) → m_tiles = ⌈B / T_M⌉ tiles. Along N/8 → n_tiles = (N/8)/T_N.&#10;W = 31 workers per XCD cooperatively walk the output tile grid with M-major traversal (within each N-column, exhaust all M rows before advancing)." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="1080" height="90" as="geometry" />
        </mxCell>

        <mxCell id="eq1Box" value="L2 hit model (Eq.(1) §6.4):&#10;R = min(W, m_tiles)  —  # workers that concurrently touch the same weight column&#10;L2 Hit_weight = (R − 1) / R = 1 − 1 / min(W, m_tiles)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;align=left;spacingLeft=10;spacingTop=6;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="180" width="1080" height="80" as="geometry" />
        </mxCell>

        <mxCell id="thH0" value="Batch B" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="60" y="280" width="100" height="25" as="geometry" />
        </mxCell>
        <mxCell id="thH1" value="m_tiles (T_M=16)" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="160" y="280" width="140" height="25" as="geometry" />
        </mxCell>
        <mxCell id="thH2" value="R = min(31, m_tiles)" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="300" y="280" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="thH3" value="Predicted Hit% = 1 − 1/R" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="460" y="280" width="200" height="25" as="geometry" />
        </mxCell>
        <mxCell id="thH4" value="Measured M-tile Hit%" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="660" y="280" width="180" height="25" as="geometry" />
        </mxCell>
        <mxCell id="thH5" value="Residual (meas − pred)" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="840" y="280" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="thH6" value="Comment" style="text;html=1;align=center;fontStyle=1;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="1000" y="280" width="140" height="25" as="geometry" />
