  <diagram id="page1" name="1. Three-Region Performance">
    <mxGraphModel dx="1280" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="600" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Qwen2.5-7B Long-Context F1 三段式性能曲线 (mixed dataset, 1000 samples)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="860" height="30" as="geometry" />
        </mxCell>
        <mxCell id="axisX" value="" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="430" as="sourcePoint" />
            <mxPoint x="980" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="axisY" value="" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="100" y="430" as="sourcePoint" />
            <mxPoint x="100" y="80" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="xLab" value="Context Length Ratio r = t / 131072  (% of 128K)" style="text;html=1;align=center;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="380" y="445" width="360" height="20" as="geometry" />
        </mxCell>
        <mxCell id="yLab" value="F1 Score = I(L)" style="text;html=1;align=center;fontSize=12;rotation=-90" vertex="1" parent="1">
          <mxGeometry x="20" y="220" width="120" height="20" as="geometry" />
        </mxCell>
        <mxCell id="stable" value="Stable Region&#10;0% ≤ r ≤ 40%&#10;F1 ≈ 0.55–0.58&#10;mean 0.565, σ=0.021&#10;≈ ≤ 51 200 tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="120" width="220" height="180" as="geometry" />
        </mxCell>
        <mxCell id="cliff" value="Critical Transition&#10;40% ≤ r ≤ 50%&#10;F1: 0.556 → 0.302&#10;ΔF1 = 45.5%  (cliff)&#10;σ=0.089 (high variance)&#10;≈ 12 800-token window" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="380" y="180" width="220" height="180" as="geometry" />
        </mxCell>
        <mxCell id="degraded" value="Degraded Region&#10;50% ≤ r ≤ 95%&#10;F1 ≈ 0.25–0.30&#10;mean 0.278, σ=0.034&#10;NO recovery beyond Lc&#10;p&lt;0.001, Cohen's d=8.2" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="640" y="240" width="280" height="180" as="geometry" />
        </mxCell>
        <mxCell id="lc" value="Lc = 43.2% ≈ 55 296 tokens&#10;(median of 5 detection methods, σ=1.2%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="380" width="320" height="40" as="geometry" />
        </mxCell>
        <mxCell id="lcArrow" value="" style="endArrow=open;html=1;strokeWidth=1.5;dashed=1;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="500" y="380" as="sourcePoint" />
            <mxPoint x="490" y="430" as="targetPoint" />
          </mxGeometry>
        </mxCell>
        <mxCell id="practitioner" value="Practitioner rule of thumb: keep prompt length &lt; 40% of advertised context (≈ 51 200 tokens for 128K models) to stay safely on the plateau." style="text;html=1;align=center;fontSize=11;fontStyle=2;fillColor=#dae8fc;strokeColor=#6c8ebf;rounded=1" vertex="1" parent="1">
          <mxGeometry x="120" y="490" width="800" height="40" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page2" name="2. Three-Bottleneck Causal Model">
    <mxGraphModel dx="1280" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title2" value="Unified Framework: Lc = min{ L_RoPE , L_attention , L_info }  (Theorem 1)" style="text;html=1;align=center;verticalAlign=middle;fontSize=16;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="980" height="30" as="geometry" />
        </mxCell>
        <mxCell id="rope" value="① RoPE Position Aliasing&#10;------&#10;θ_RoPE ≈ 1e-4&#10;P ≈ 2π/θ ≈ 62 832 tok&#10;L_RoPE ≈ α·P,  α ∈ [0.4, 0.5]&#10;⇒ L_RoPE ≈ 49% of 131 072&#10;------&#10;Mechanism: distant positions become indistinguishable when the rotation angle wraps around" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="attn" value="② Attention Dispersion&#10;------&#10;C(A,L) = (1/L) Σ max_j A_ij(L)&#10;decays exponentially with L&#10;H(A|L) entropy ↑&#10;⇒ L_attention ≈ 42–43%&#10;------&#10;Mechanism: softmax 在长序列下趋近均匀分布，模型无法聚焦到 relevant token" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="460" y="100" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="info" value="③ Information Bottleneck&#10;------&#10;η(L) = I(X;Y|L) / H(X|L)&#10;η ↓ as L ↑ due to:&#10; • compression to fixed dim&#10; • noise accumulation&#10; • attention saturation&#10;⇒ L_info ≈ 42–44%&#10;------&#10;Mechanism: 模型必须把更多信息压进固定 hidden state，互信息衰减" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="840" y="100" width="280" height="200" as="geometry" />
        </mxCell>
        <mxCell id="min" value="Lc = min{ 49% , 43% , 43% } ≈ 43.2%&#10;(empirical median)" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="450" y="380" width="300" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="rope" target="min">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="attn" target="min">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="info" target="min">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="insight" value="Key insight (paper §6.2): RoPE 单独预测 49%，但实测 43.2%。&#10;说明 attention 弥散 / 信息瓶颈 比 RoPE aliasing 更早触发，是真正的 limiting factor。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=2;align=center" vertex="1" parent="1">
          <mxGeometry x="200" y="520" width="800" height="60" as="geometry" />
        </mxCell>
        <mxCell id="effect" value="Catastrophic effect (Definition 3): Abruptness D(Lc)&gt;30%  AND  Persistence I(L&gt;Lc)&lt;0.5·I(L&lt;Lc)" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fillColor=#e1d5e7;strokeColor=#9673a6" vertex="1" parent="1">
          <mxGeometry x="200" y="600" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="effArrow" style="endArrow=classic;html=1;strokeWidth=2;" edge="1" parent="1" source="min" target="effect">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page3" name="3. Five-Method Cross-Validation">
    <mxGraphModel dx="1280" dy="720" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="t3" value="Threshold Detection Pipeline (Algorithm 4): 1000 (r,F1) pairs → 5 detectors → median" style="text;html=1;align=center;verticalAlign=middle;fontSize=15;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="20" width="1040" height="30" as="geometry" />
        </mxCell>
        <mxCell id="data" value="Input&#10;{(r_i , F1_i)}_{i=1}^{1000}&#10;r_i = t_i / 131 072 (NATURAL, no truncation)&#10;500 SQuAD (r∈5–10%) + 500 NarrativeQA (r∈20–95%)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="280" height="100" as="geometry" />
        </mxCell>
        <mxCell id="m1" value="M1 Gradient Analysis&#10;(multi-peak, w=5, hmin=0.3)&#10;→ 42.5%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="60" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m2" value="M2 Second Derivative&#10;(max negative acceleration)&#10;→ 43.2%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="135" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m3" value="M3 Binned Statistics&#10;(20 bins, peak in 35–55%)&#10;→ 45.0%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="210" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m4" value="M4 Percentile Threshold&#10;(top-percentile peak filter)&#10;→ 41.8%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="285" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="m5" value="M5 Sliding Window&#10;(MA filter w=5, smoothed peak)&#10;→ 44.5%" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="440" y="360" width="240" height="60" as="geometry" />
        </mxCell>
        <mxCell id="med" value="Median(R)&#10;= 43.2%&#10;σ_rc = 1.2%&#10;⇒ confidence: HIGH" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=13;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="800" y="180" width="200" height="120" as="geometry" />
        </mxCell>
        <mxCell id="filter" value="Common 3-stage filter (M1, M2, M4, M5):&#10;(a) Multi-peak detection in r ∈ [0.30, 0.60]&#10;(b) Rise-in-range filter (next 10% must NOT rise)&#10;(c) Sustained-decline verification (post-peak max &lt; 0.85·Pp)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left" vertex="1" parent="1">
          <mxGeometry x="60" y="220" width="320" height="120" as="geometry" />
        </mxCell>
        <mxCell id="d1" style="endArrow=classic;html=1;" edge="1" parent="1" source="data" target="m1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d2" style="endArrow=classic;html=1;" edge="1" parent="1" source="data" target="m2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d3" style="endArrow=classic;html=1;" edge="1" parent="1" source="data" target="m3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d4" style="endArrow=classic;html=1;" edge="1" parent="1" source="data" target="m4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d5" style="endArrow=classic;html=1;" edge="1" parent="1" source="data" target="m5"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m1m" style="endArrow=classic;html=1;" edge="1" parent="1" source="m1" target="med"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m2m" style="endArrow=classic;html=1;" edge="1" parent="1" source="m2" target="med"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m3m" style="endArrow=classic;html=1;" edge="1" parent="1" source="m3" target="med"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m4m" style="endArrow=classic;html=1;" edge="1" parent="1" source="m4" target="med"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="m5m" style="endArrow=classic;html=1;" edge="1" parent="1" source="m5" target="med"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="caveat" value="⚠ Method-independence caveat: M1, M2, M4, M5 share the same 3-stage filter and only differ in selection criterion ⇒ low effective σ. M3 is the only structurally different detector. 5σ=1.2% may overstate independence." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="80" y="480" width="1040" height="60" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
