  </diagram>

  <diagram id="page3" name="3. Hypothesised mitigations">
    <mxGraphModel dx="1422" dy="753" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1100" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t" value="Why has LITM disappeared in Gemini 2.5 Flash?  (Hypothesis tree)" style="text;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1020" height="32" as="geometry" />
        </mxCell>

        <mxCell id="root" value="LITM disappears at 1M context\n(this paper's observation)" style="rounded=1;fillColor=#dcffe4;strokeColor=#137333;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="420" y="80" width="260" height="60" as="geometry" />
        </mxCell>

        <mxCell id="h1" value="H1. Position-encoding upgrade\n(ALiBi / NoPE / 3D-RoPE / interpolation)" style="rounded=1;fillColor=#dceeff;strokeColor=#1f6feb;align=center" vertex="1" parent="1">
          <mxGeometry x="40" y="200" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h2" value="H2. Training curriculum\n(NIAH-style data + long-context up-sampling)" style="rounded=1;fillColor=#fff4d6;strokeColor=#a16207;align=center" vertex="1" parent="1">
          <mxGeometry x="360" y="200" width="280" height="80" as="geometry" />
        </mxCell>
        <mxCell id="h3" value="H3. Architectural changes\n(sparse / linear / hybrid attn,\nmulti-query, KV compression)" style="rounded=1;fillColor=#f0e6ff;strokeColor=#6b3fa0;align=center" vertex="1" parent="1">
          <mxGeometry x="680" y="200" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;exitX=0.3;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="root" target="h1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="root" target="h2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="root" target="h3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="h1d" value="Evidence:\n• ALiBi paper (Press 2022)\n• Gemini 1.5 report mentions long-ctx pos-enc\nUnknown: which exactly Gemini 2.5 uses\n(Google has not published)" style="rounded=1;fillColor=#eef5ff;strokeColor=#1f6feb;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="h2d" value="Evidence:\n• Gemini 1.5 report explicitly stresses NIAH\n• HELMET, multi-needle benchmarks confirm\n  single-needle is now ~saturated\nThis is the most plausible direct cause" style="rounded=1;fillColor=#fffbe6;strokeColor=#a16207;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="360" y="320" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="h3d" value="Evidence:\n• Gemini 2.5 paper hints at sparse/long-ctx tricks\n• Behaviour at 1.05M-token rejection suggests\n  block-sparse / sliding window pre-empts overflow\nMostly speculative without weights" style="rounded=1;fillColor=#f3ebff;strokeColor=#6b3fa0;align=left;spacingLeft=8;spacingTop=6" vertex="1" parent="1">
          <mxGeometry x="680" y="320" width="280" height="120" as="geometry" />
        </mxCell>

        <mxCell id="caveat" value="Open caveats / next failure modes (paper acknowledges):\n• Multi-needle (LangChain 2024) — accuracy drops sharply\n• Multi-hop reasoning over long context — not tested\n• Multimodal (Vaidya 2025) — accuracy drops\n• Adversarial / paraphrased / contradictory queries — untested\n⇒ The disappearance of LITM in single-needle does NOT mean long-context is &quot;solved&quot;.\n   It just means RAG and chunking are no longer mandatory for this narrow task." style="rounded=1;fillColor=#fff5f5;strokeColor=#d1242f;align=left;spacingLeft=10;spacingTop=8;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="40" y="470" width="920" height="160" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
