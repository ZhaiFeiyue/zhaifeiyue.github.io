<mxfile host="app.diagrams.net" modified="2026-04-19T05:55:00.000Z" agent="paper-reader" version="24.7.0">
  <diagram id="page1" name="1. LITM vs Gemini2.5">
    <mxGraphModel dx="1422" dy="753" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1100" pageHeight="650" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title1" value="LITM (2023, GPT-3.5 / Llama-2)  vs.  Gemini 2.5 Flash (2025, this paper)" style="text;html=1;align=center;verticalAlign=middle;fontSize=18;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="120" y="20" width="860" height="40" as="geometry" />
        </mxCell>

        <mxCell id="leftBox" value="" style="rounded=1;fillColor=#fff5f5;strokeColor=#d1242f;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="60" y="80" width="500" height="540" as="geometry" />
        </mxCell>
        <mxCell id="lhead" value="2023 setup — Liu et al." style="text;align=center;fontSize=14;fontStyle=1;fontColor=#7d1a1a" vertex="1" parent="1">
          <mxGeometry x="60" y="92" width="500" height="28" as="geometry" />
        </mxCell>

        <mxCell id="lctx" value="Context window: 4K – 32K tokens&#10;Models: GPT-3.5, Llama-2, MPT-30B&#10;Position encoding: vanilla RoPE / learned&#10;Training data: not NIAH-curated" style="rounded=1;fillColor=#fde8e8;strokeColor=#d1242f" vertex="1" parent="1">
          <mxGeometry x="80" y="130" width="460" height="80" as="geometry" />
        </mxCell>

        <mxCell id="lcurve" value="" style="shape=image;image=data:image/svg+xml,%3Csvg xmlns%3D%27http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%27 viewBox%3D%270 0 220 100%27%3E%3Cpath d%3D%27M5 25 Q60 95 110 95 Q160 95 215 25%27 stroke%3D%27%23d1242f%27 stroke-width%3D%274%27 fill%3D%27none%27%2F%3E%3C%2Fsvg%3E" vertex="1" parent="1">
          <mxGeometry x="170" y="240" width="280" height="160" as="geometry" />
        </mxCell>
        <mxCell id="lcurvelbl" value="U-shape: ~95% at edges, ~55% at center&#10;(Lost-in-the-Middle)" style="text;align=center;fontSize=11;fontColor=#7d1a1a;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="120" y="400" width="380" height="36" as="geometry" />
        </mxCell>

        <mxCell id="lcause" value="Root causes claimed by literature:&#10;• Causal attention mask + relative pos enc&#10;• RoPE long-distance decay&#10;• Primacy / recency bias from softmax dynamics&#10;• Pre-training data lacks middle-needle supervision" style="rounded=1;fillColor=#fbeaea;strokeColor=#d1242f;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="80" y="450" width="460" height="150" as="geometry" />
        </mxCell>

        <mxCell id="rightBox" value="" style="rounded=1;fillColor=#f0f7ff;strokeColor=#1f6feb;strokeWidth=2" vertex="1" parent="1">
          <mxGeometry x="600" y="80" width="440" height="540" as="geometry" />
        </mxCell>
        <mxCell id="rhead" value="2025 setup — McKinnon (this paper)" style="text;align=center;fontSize=14;fontStyle=1;fontColor=#1f3a6e" vertex="1" parent="1">
          <mxGeometry x="600" y="92" width="440" height="28" as="geometry" />
        </mxCell>

        <mxCell id="rctx" value="Context window: ≈1.05M tokens (Gemini 2.5 Flash)&#10;Probed with 70% of Friends transcript (≈647k words)&#10;20 needles → 26 Q&amp;A factoids, equidistant&#10;Single batched query, T=0.1, thinking off" style="rounded=1;fillColor=#dceeff;strokeColor=#1f6feb" vertex="1" parent="1">
          <mxGeometry x="620" y="130" width="400" height="80" as="geometry" />
        </mxCell>

        <mxCell id="rcurve" value="" style="shape=image;image=data:image/svg+xml,%3Csvg xmlns%3D%27http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%27 viewBox%3D%270 0 220 100%27%3E%3Cline x1%3D%275%27 y1%3D%2718%27 x2%3D%27215%27 y2%3D%2718%27 stroke%3D%27%231f6feb%27 stroke-width%3D%274%27%2F%3E%3Ccircle cx%3D%2730%27 cy%3D%2718%27 r%3D%276%27 fill%3D%27%231f6feb%27%2F%3E%3Ccircle cx%3D%2760%27 cy%3D%2718%27 r%3D%276%27 fill%3D%27%231f6feb%27%2F%3E%3Ccircle cx%3D%2790%27 cy%3D%2718%27 r%3D%276%27 fill%3D%27%231f6feb%27%2F%3E%3Ccircle cx%3D%27120%27 cy%3D%2718%27 r%3D%276%27 fill%3D%27%231f6feb%27%2F%3E%3Ccircle cx%3D%27150%27 cy%3D%2718%27 r%3D%276%27 fill%3D%27%231f6feb%27%2F%3E%3Ccircle cx%3D%27180%27 cy%3D%2718%27 r%3D%276%27 fill%3D%27%231f6feb%27%2F%3E%3C%2Fsvg%3E" vertex="1" parent="1">
          <mxGeometry x="620" y="270" width="400" height="120" as="geometry" />
        </mxCell>
        <mxCell id="rcurvelbl" value="Flat 100% across all 7 tested ratios&#10;(0.13 → 0.92 of context window)" style="text;align=center;fontSize=11;fontColor=#1f3a6e;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="620" y="400" width="400" height="36" as="geometry" />
        </mxCell>

        <mxCell id="rcause" value="Hypothesised mitigations:&#10;• ALiBi-style (or relative) positional bias&#10;• Training curriculum stresses NIAH at long ctx&#10;• 1.5M-tok pre-training data&#10;• Architectural changes Google has not disclosed" style="rounded=1;fillColor=#e3eeff;strokeColor=#1f6feb;align=left;verticalAlign=top;spacingLeft=10;spacingTop=8" vertex="1" parent="1">
          <mxGeometry x="620" y="450" width="400" height="150" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>

  <diagram id="page2" name="2. Experiment pipeline">
    <mxGraphModel dx="1422" dy="753" grid="1" gridSize="10" page="1" pageScale="1" pageWidth="1200" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="t" value="Closed-loop experimental pipeline (validates true context limit + retrieval accuracy in one sweep)" style="text;align=center;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="60" y="20" width="1080" height="32" as="geometry" />
        </mxCell>

        <mxCell id="b1" value="① Friends transcript&#10;924k words&#10;(&gt;1M tokens)" style="rounded=1;fillColor=#e6e6e6;strokeColor=#666" vertex="1" parent="1">
          <mxGeometry x="60" y="120" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b2" value="② Trim to ratio r&#10;r ∈ {0.1, 0.2, …, 0.8}&#10;of full corpus" style="rounded=1;fillColor=#fff4d6;strokeColor=#a16207" vertex="1" parent="1">
          <mxGeometry x="260" y="120" width="160" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b3" value="③ Inject 20 non-canon snippets&#10;equidistant across the slice&#10;(one at start, one at end)" style="rounded=1;fillColor=#fde8e8;strokeColor=#d1242f" vertex="1" parent="1">
          <mxGeometry x="460" y="120" width="220" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b4" value="④ Build prompt&#10;= context + 26 Q&amp;A&#10;in single batched call" style="rounded=1;fillColor=#dceeff;strokeColor=#1f6feb" vertex="1" parent="1">
          <mxGeometry x="720" y="120" width="200" height="80" as="geometry" />
        </mxCell>

        <mxCell id="b5" value="⑤ Gemini 2.5 Flash&#10;T=0.1, thinking off&#10;no system instruction" style="rounded=1;fillColor=#cfe9ff;strokeColor=#1f6feb;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="960" y="120" width="180" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e1" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="b1" target="b2">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="b2" target="b3">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="b3" target="b4">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0" edge="1" parent="1" source="b4" target="b5">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="ok" value="HTTP 200 OK&#10;parse N answers" style="rounded=1;fillColor=#dcffe4;strokeColor=#137333" vertex="1" parent="1">
          <mxGeometry x="700" y="280" width="200" height="60" as="geometry" />
        </mxCell>
        <mxCell id="rej" value="HTTP 400&#10;&quot;input token count … exceeds 1,048,576&quot;&#10;⇒ true context limit located" style="rounded=1;fillColor=#ffe0e0;strokeColor=#d1242f" vertex="1" parent="1">
          <mxGeometry x="940" y="280" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="e5a" style="endArrow=classic;html=1;exitX=0.4;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="b5" target="ok">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5b" style="endArrow=classic;html=1;exitX=0.7;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="b5" target="rej">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="judge" value="⑥ Judge model&#10;(fresh Gemini 2.5 Flash)&#10;compares to ground truth + manual review" style="rounded=1;fillColor=#f0e6ff;strokeColor=#6b3fa0" vertex="1" parent="1">
          <mxGeometry x="660" y="400" width="280" height="80" as="geometry" />
        </mxCell>

        <mxCell id="e6" style="endArrow=classic;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0" edge="1" parent="1" source="ok" target="judge">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <mxCell id="abl" value="Ablation control:&#10;ask without injection ⇒ model says &quot;unknown flavor&quot;&#10;⇒ confirms the answer comes from the needle, not training memory" style="rounded=1;fillColor=#fffbe0;strokeColor=#a16207;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="60" y="400" width="540" height="80" as="geometry" />
        </mxCell>

        <mxCell id="result" value="Result table (Table I, this paper):&#10;ratio 0.1–0.7 → 26/26 correct (100%)&#10;ratio 0.8 → request rejected" style="rounded=1;fillColor=#dcffe4;strokeColor=#137333;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="660" y="540" width="380" height="80" as="geometry" />
