<?xml version="1.0" encoding="UTF-8"?>
<mxfile host="app.diagrams.net" modified="2026-04-18" agent="paper-reader" version="24.0" type="device">

  <!-- Page 1: High-level Joint AV Generation Pipeline (inferred from 1.5 pro) -->
  <diagram id="page1" name="1. AV Joint Pipeline (inferred)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Seedance 2.0 — Native Audio-Video Joint Generation (architecture inferred from Seedance 1.5 pro: dual-branch MMDiT)" style="text;align=left;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1500" height="30" as="geometry"/>
        </mxCell>

        <!-- Inputs (4 modalities) -->
        <mxCell id="in_text" value="Text Prompt&#xa;(storyboard, dialect, dialogue)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="in_img" value="Image Reference&#xa;up to 9 images" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="170" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="in_vid" value="Video Reference&#xa;up to 3 clips&#xa;(motion / style / VFX / 1st-frame)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="260" width="200" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="in_aud" value="Audio Reference&#xa;up to 3 clips&#xa;(timbre / BGM)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="370" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Encoders -->
        <mxCell id="enc_text" value="Text Encoder&#xa;(LLM / T5-style)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="80" width="180" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="enc_vis" value="Visual Encoder + 3D-VAE&#xa;(image / video → latent tokens)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="200" width="180" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="enc_aud" value="Audio Encoder&#xa;(spec / wav → latent tokens)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="370" width="180" height="80" as="geometry"/>
        </mxCell>

        <!-- Backbone: Dual-branch MMDiT -->
        <mxCell id="dit_box" value="" style="rounded=1;whiteSpace=wrap;fillColor=none;strokeColor=#000000;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="60" width="540" height="430" as="geometry"/>
        </mxCell>
        <mxCell id="dit_lbl" value="Unified Multi-Modal Joint Backbone — MMDiT (dual-branch DiT, large-scale)" style="text;align=center;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="70" width="520" height="20" as="geometry"/>
        </mxCell>

        <mxCell id="vid_branch" value="Video DiT Branch&#xa;(noisy latent video)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="630" y="110" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="aud_branch" value="Audio DiT Branch&#xa;(noisy latent audio, dual-channel)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="890" y="110" width="220" height="60" as="geometry"/>
        </mxCell>

        <mxCell id="cross_mod" value="Cross-Modal Joint Module&#xa;(deep AV cross-attention&#xa;for temporal sync &amp; semantic consistency)" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="210" width="340" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="text_cond" value="Text-conditioning injection (cross-attn / AdaLN)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="320" width="340" height="50" as="geometry"/>
        </mxCell>

        <mxCell id="repeat" value="× N MMDiT blocks&#xa;(joint denoising at each step)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="700" y="400" width="340" height="60" as="geometry"/>
        </mxCell>

        <!-- Decoders -->
        <mxCell id="vae_dec" value="Video VAE Decoder&#xa;→ 480p / 720p, 4-15s" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1220" y="100" width="200" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="aud_dec" value="Audio Decoder&#xa;→ binaural waveform&#xa;(speech + SFX + BGM tracks)" style="rounded=1;whiteSpace=wrap;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="1220" y="200" width="200" height="80" as="geometry"/>
        </mxCell>

        <!-- Outputs -->
        <mxCell id="out" value="Synchronized&#xa;Audio + Video&#xa;(4-15s, 480p/720p)" style="rounded=1;whiteSpace=wrap;fillColor=#d4edda;strokeColor=#28a745;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1450" y="150" width="120" height="80" as="geometry"/>
        </mxCell>

        <!-- Acceleration callout -->
        <mxCell id="fast" value="Seedance 2.0 Fast variant&#xa;multi-stage distillation → low NFE&#xa;(inherits 10× speedup recipe from 1.5)" style="rounded=1;whiteSpace=wrap;fillColor=#ffe6e6;strokeColor=#d62728;fontSize=10;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="700" y="490" width="340" height="60" as="geometry"/>
        </mxCell>

        <!-- Edges: inputs to encoders -->
        <mxCell id="e1" style="endArrow=classic;html=1;" edge="1" parent="1" source="in_text" target="enc_text"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;" edge="1" parent="1" source="in_img" target="enc_vis"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;" edge="1" parent="1" source="in_vid" target="enc_vis"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;" edge="1" parent="1" source="in_aud" target="enc_aud"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: encoders to backbone -->
        <mxCell id="e5" style="endArrow=classic;html=1;" edge="1" parent="1" source="enc_text" target="text_cond"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;" edge="1" parent="1" source="enc_vis" target="vid_branch"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;" edge="1" parent="1" source="enc_aud" target="aud_branch"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: cross-modal joint -->
        <mxCell id="e8" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="vid_branch" target="cross_mod"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;dashed=1;" edge="1" parent="1" source="aud_branch" target="cross_mod"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: backbone to decoders -->
        <mxCell id="e10" style="endArrow=classic;html=1;" edge="1" parent="1" source="vid_branch" target="vae_dec"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e11" style="endArrow=classic;html=1;" edge="1" parent="1" source="aud_branch" target="aud_dec"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Edges: decoders to output -->
        <mxCell id="e12" style="endArrow=classic;html=1;" edge="1" parent="1" source="vae_dec" target="out"><mxGeometry relative="1" as="geometry"/></mxCell>
        <mxCell id="e13" style="endArrow=classic;html=1;" edge="1" parent="1" source="aud_dec" target="out"><mxGeometry relative="1" as="geometry"/></mxCell>

        <!-- Note -->
        <mxCell id="note" value="⚠️ Note: Seedance 2.0 paper is a release/eval report — it does NOT disclose architecture / training details.&#xa;This diagram is reconstructed from Seedance 1.5 pro paper [arXiv:2512.13507] which describes the dual-branch MMDiT architecture inherited by 2.0." style="text;align=left;fontSize=10;fontStyle=2;fillColor=#fff8dc;strokeColor=#cccc66;" vertex="1" parent="1">
          <mxGeometry x="40" y="600" width="1500" height="50" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>

