<mxfile host="65bd71144e">
  <diagram name="PCD Pipeline" id="page-pcd-overview">
    <mxGraphModel dx="1422" dy="797" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" value="Positional Contrastive Decoding (PCD) — End-to-End Pipeline" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1;fontColor=#1B2A4A" vertex="1" parent="1">
          <mxGeometry x="240" y="20" width="920" height="40" as="geometry" />
        </mxCell>
        <mxCell id="input" value="Long-Context Input&#xa;x = [x₁, ..., x_L]&#xa;L up to 1M tokens&#xa;(e.g. RULER / InfiniteBench)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="180" height="100" as="geometry" />
        </mxCell>
        <mxCell id="path-long" value="Path A: Long-Aware Forward&#xa;(standard RoPE base B)&#xa;θⱼ = B^(-2(j-1)/d)&#xa;B = 5e5 (Llama-3 default)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="280" y="180" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="model-long" value="Llama-3-8B&#xa;(32 layers, 32H/8KV GQA)&#xa;Standard RoPE attention" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="540" y="180" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="logit-L" value="Standard logits L&#xa;∈ ℝ^|V|&#xa;|V|=128256" style="ellipse;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="180" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="path-local" value="Path B: Local-Aware Forward&#xa;(perturbed RoPE base B')&#xa;θ*ⱼ = T(j/d/2)·θⱼ + (1-T)·θ'ⱼ&#xa;B/B' = 1e4, T(x) = 2-exp(αx)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="280" y="480" width="200" height="80" as="geometry" />
        </mxCell>
        <mxCell id="model-local" value="Llama-3-8B (same θ)&#xa;Modified RoPE attention&#xa;over-rotate low-freq blocks" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="540" y="480" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="logit-Lstar" value="Local-aware logits L*&#xa;∈ ℝ^|V|&#xa;sharper local decay" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="780" y="480" width="160" height="80" as="geometry" />
        </mxCell>
        <mxCell id="topk" value="Top-γ Selector&#xa;γ = 30&#xa;(restrict contrast to&#xa;top candidates of L)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="990" y="320" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="contrast" value="Contrastive Logits&#xa;L̃ = (1+β)·L − β·L*&#xa;β = 2.5 (only on top-γ)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1200" y="320" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="output" value="Sampled token y*&#xa;(argmax / sample of L̃)&#xa;→ gold token rank ↑" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1230" y="480" width="160" height="100" as="geometry" />
        </mxCell>
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#6c8ebf" edge="1" parent="1" source="input" target="path-long">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" style="endArrow=classic;html=1;rounded=0;strokeWidth=2;strokeColor=#b85450" edge="1" parent="1" source="input" target="path-local">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e3" style="endArrow=classic;html=1;rounded=0;strokeColor=#82b366;strokeWidth=2" edge="1" parent="1" source="path-long" target="model-long">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e4" style="endArrow=classic;html=1;rounded=0;strokeColor=#82b366;strokeWidth=2" edge="1" parent="1" source="model-long" target="logit-L">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e5" style="endArrow=classic;html=1;rounded=0;strokeColor=#b85450;strokeWidth=2" edge="1" parent="1" source="path-local" target="model-local">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e6" style="endArrow=classic;html=1;rounded=0;strokeColor=#b85450;strokeWidth=2" edge="1" parent="1" source="model-local" target="logit-Lstar">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e7" style="endArrow=classic;html=1;rounded=0;strokeColor=#9673a6;strokeWidth=2" edge="1" parent="1" source="logit-L" target="topk">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e8" style="endArrow=classic;html=1;rounded=0;strokeColor=#9673a6;strokeWidth=2" edge="1" parent="1" source="logit-Lstar" target="topk">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e9" style="endArrow=classic;html=1;rounded=0;strokeColor=#82b366;strokeWidth=3" edge="1" parent="1" source="topk" target="contrast">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e10" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=3" edge="1" parent="1" source="contrast" target="output">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="legend" value="Key insight: contrastive logits cancel proximal-token bias.&#xa;Theorem A.5 → decay rate ratio (ln B'/ln B)^(2/d) &lt; 1&#xa;Net effect: gold-token salience S(L) is preserved at long L." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=11;fontStyle=2;align=left" vertex="1" parent="1">
          <mxGeometry x="40" y="640" width="700" height="100" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="RoPE Rotation" id="page-rope-internals">
    <mxGraphModel dx="1422" dy="797" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title2" value="RoPE Frequency Decomposition: high-freq local vs low-freq global" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1B2A4A" vertex="1" parent="1">
          <mxGeometry x="200" y="20" width="1000" height="40" as="geometry" />
        </mxCell>
        <mxCell id="x" value="Token embedding x_m ∈ ℝ^d&#xa;d = 128 (Llama-3 head_dim)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="40" y="320" width="180" height="80" as="geometry" />
        </mxCell>
        <mxCell id="wq" value="W_q (proj)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12" vertex="1" parent="1">
          <mxGeometry x="280" y="320" width="100" height="80" as="geometry" />
        </mxCell>
        <mxCell id="freq-split" value="Split into d/2 = 64 frequency blocks&#xa;θⱼ = B^(-2(j-1)/d)&#xa;j = 1, 2, ..., 64" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="440" y="320" width="220" height="80" as="geometry" />
        </mxCell>
        <mxCell id="hi-freq" value="High-Frequency Blocks (j small)&#xa;θⱼ ≈ 1 (large angles)&#xa;rotates fast → senses LOCAL detail&#xa;e.g. j=1: θ₁=1.0, every token rotates fully&#xa;→ Distinguishes adjacent tokens" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="720" y="180" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="lo-freq" value="Low-Frequency Blocks (j large)&#xa;θⱼ ≈ B^(-1) ≈ 2e-6 (tiny angles)&#xa;rotates slow → captures GLOBAL pattern&#xa;e.g. j=64: only completes 1 full rotation per ~1M tokens&#xa;→ Distinguishes far-apart token clusters" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11" vertex="1" parent="1">
          <mxGeometry x="720" y="440" width="280" height="120" as="geometry" />
        </mxCell>
        <mxCell id="perturb-hi" value="❌ Perturb HIGH-freq&#xa;→ destroys local structure&#xa;→ MODEL COLLAPSE&#xa;(Appendix A.6)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=11;fontStyle=1;fontColor=#b85450" vertex="1" parent="1">
          <mxGeometry x="1060" y="180" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="perturb-lo" value="✓ Perturb LOW-freq&#xa;θⱼ' = (B')^(-2(j-1)/d), B'=50&#xa;→ over-rotate slow blocks&#xa;→ enhanced local awareness&#xa;→ feed into PCD as L*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="1060" y="440" width="240" height="120" as="geometry" />
        </mxCell>
        <mxCell id="trans" value="Transition Function&#xa;T(x) = 2 − exp(α·x), α=0.2&#xa;blends from high → low&#xa;θ*ⱼ = T·θⱼ + (1−T)·θⱼ'&#xa;(eq. 4)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="440" y="600" width="220" height="120" as="geometry" />
        </mxCell>
        <mxCell id="rxx" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=2" edge="1" parent="1" source="x" target="wq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="ryy" style="endArrow=classic;html=1;rounded=0;strokeColor=#6c8ebf;strokeWidth=2" edge="1" parent="1" source="wq" target="freq-split">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rzz1" style="endArrow=classic;html=1;rounded=0;strokeColor=#82b366;strokeWidth=2" edge="1" parent="1" source="freq-split" target="hi-freq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rzz2" style="endArrow=classic;html=1;rounded=0;strokeColor=#b85450;strokeWidth=2" edge="1" parent="1" source="freq-split" target="lo-freq">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="raa1" style="endArrow=classic;html=1;rounded=0;strokeColor=#d79b00;strokeWidth=2" edge="1" parent="1" source="hi-freq" target="perturb-hi">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="raa2" style="endArrow=classic;html=1;rounded=0;strokeColor=#82b366;strokeWidth=2" edge="1" parent="1" source="lo-freq" target="perturb-lo">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="rbb" style="endArrow=classic;html=1;rounded=0;strokeColor=#9673a6;strokeWidth=2" edge="1" parent="1" source="freq-split" target="trans">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram name="Decay Comparison" id="page-decay-curves">
    <mxGraphModel dx="1422" dy="797" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title3" value="Three Decay Regimes — Why Contrast Wins" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=18;fontStyle=1;fontColor=#1B2A4A" vertex="1" parent="1">
          <mxGeometry x="300" y="20" width="800" height="40" as="geometry" />
        </mxCell>
        <mxCell id="r-std" value="REGIME 1: Standard RoPE (base B)&#xa;|S(k)| ≤ C₁·k^(-d/2)·exp(-k^(2/d)·ln B)&#xa;→ algebraic decay; Theorem 4.3 (RoFormer)&#xa;Long-tokens: weak signal, dominated by proximal" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r-loc" value="REGIME 2: Local-Aware (over-rotated B')&#xa;|S'(k)| decays even FASTER&#xa;→ very strong proximal bias&#xa;Designed to exaggerate the failure mode" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;align=left;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="320" width="380" height="140" as="geometry" />
        </mxCell>
        <mxCell id="r-cd" value="REGIME 3: PCD = (1+β)·S − β·S'&#xa;Net decay rate ratio (ln B'/ln B)^(2/d) &lt; 1&#xa;→ decay rate REDUCED&#xa;→ long-range attention preserved&#xa;Theorem A.5: lim sup ln|S_CD(k)| / ln|S(k)| &lt; 1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=left;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="520" width="380" height="160" as="geometry" />
        </mxCell>
        <mxCell id="formula" value="Numerical example (Llama-3, d=128):&#xa;B = 5e5,  B' = 50  →  B/B' = 1e4&#xa;ln B = 13.12,  ln B' = 3.91&#xa;Decay rate ratio = (3.91/13.12)^(2/128)&#xa;                  = 0.298^(0.0156)&#xa;                  ≈ 0.981&#xa;→ ~2% slower decay per power of k&#xa;→ over many positions, signal is preserved&#xa;&#xa;Empirical (Fig 3b at L=16384):&#xa;Standard:    S(L) ≈ 7&#xa;Local-aware: S(L) ≈ -2&#xa;Contrastive: S(L) ≈ 12  ← long-range PRESERVED" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=left" vertex="1" parent="1">
          <mxGeometry x="540" y="120" width="700" height="380" as="geometry" />
        </mxCell>
        <mxCell id="bottom-line" value="Bottom line: PCD does not fight RoPE decay directly; it constructs a&#xa;deliberately worse local-only baseline and SUBTRACTS it from standard logits.&#xa;What's left after subtraction is precisely the long-range gain from short-to-long training." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff4e6;strokeColor=#d79b00;fontSize=12;align=left;fontStyle=2" vertex="1" parent="1">
          <mxGeometry x="540" y="540" width="700" height="140" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
