  <diagram id="page2" name="5-Layer Subsystem">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title2" value="5-Layer Subsystem Decomposition" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#1B2A4A;" vertex="1" parent="1">
          <mxGeometry x="400" y="20" width="350" height="40" as="geometry"/>
        </mxCell>
        <!-- Surface Layer -->
        <mxCell id="surface" value="Surface Layer&#xa;Interactive CLI | Headless CLI | Agent SDK | IDE/Desktop/Browser | UI/Renderer" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="900" height="50" as="geometry"/>
        </mxCell>
        <!-- Core Layer -->
        <mxCell id="core" value="Core Layer&#xa;queryLoop() Agent Loop | 5-Layer Compaction Pipeline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontStyle=1;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="100" y="160" width="900" height="50" as="geometry"/>
        </mxCell>
        <!-- Safety/Action Layer -->
        <mxCell id="safety" value="Safety / Action Layer&#xa;Permission System (7 modes, deny-first) | Auto-Mode ML Classifier | Hook Pipeline (27 events) | Extensibility (MCP + Plugins + Skills + Hooks) | Built-in Tools (54) | MCP Tools | Shell Sandbox | Subagent Spawning" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="240" width="900" height="80" as="geometry"/>
        </mxCell>
        <!-- State Layer -->
        <mxCell id="statel" value="State Layer&#xa;Context Assembly (memoized) | Runtime State | Session Persistence (append-only JSONL) | CLAUDE.md 4-level Hierarchy + Auto Memory | Sidechain Transcripts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="350" width="900" height="60" as="geometry"/>
        </mxCell>
        <!-- Backend Layer -->
        <mxCell id="backend" value="Backend Layer&#xa;Shell Execution (Bash/PowerShell + sandbox) | MCP Server Connections (8+ transports) | Remote Execution | 42 Tool Subdirectories" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontStyle=1;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="100" y="440" width="900" height="50" as="geometry"/>
        </mxCell>
        <!-- Key files -->
        <mxCell id="files" value="Key Source Files&#xa;query.ts (68KB) — core loop + 5 context shapers&#xa;permissions.ts — deny-first rule evaluation&#xa;tools.ts — assembleToolPool() single source of truth&#xa;AgentTool.tsx — subagent dispatch&#xa;sessionStorage.ts — append-only JSONL transcripts&#xa;claudemd.ts — 4-level memory hierarchy" style="shape=note;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="530" width="400" height="120" as="geometry"/>
        </mxCell>
        <!-- Context Compaction Pipeline -->
        <mxCell id="compact" value="5-Layer Context Compaction Pipeline&#xa;① Budget Reduction (always on) → ② Snip (HISTORY_SNIP) →&#xa;③ Microcompact (CACHED_MICROCOMPACT) → ④ Context Collapse (CONTEXT_COLLAPSE) →&#xa;⑤ Auto-compact (model-generated summary, last resort)" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="550" y="530" width="450" height="90" as="geometry"/>
