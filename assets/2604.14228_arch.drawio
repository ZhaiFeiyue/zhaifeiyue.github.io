  </diagram>
  <diagram id="page3" name="Permission Pipeline">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="title3" value="7-Layer Safety Pipeline (Defense in Depth)" style="text;html=1;align=center;verticalAlign=middle;resizable=0;points=[];autosize=1;strokeColor=none;fillColor=none;fontSize=18;fontStyle=1;fontColor=#1B2A4A;" vertex="1" parent="1">
          <mxGeometry x="350" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        <!-- 7 safety layers -->
        <mxCell id="l1" value="① Tool Pre-filtering&#xa;filterToolsByDenyRules()&#xa;Blanket-denied tools removed before model sees them" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="80" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l2" value="② Deny-first Rule Evaluation&#xa;permissions.ts — deny rules ALWAYS override allow rules, even when allow is more specific" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="145" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l3" value="③ Permission Mode Constraints&#xa;7 modes: plan → default → acceptEdits → auto → dontAsk → bypassPermissions → bubble" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="210" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l4" value="④ Auto-mode ML Classifier&#xa;yoloClassifier.ts — LLM-based safety evaluation, allow / deny / manual approval" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="275" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l5" value="⑤ Shell Sandboxing&#xa;shouldUseSandbox.ts — filesystem + network isolation independent of permission model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="340" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l6" value="⑥ Not Restoring Permissions on Resume&#xa;Session-scoped permissions not serialized — resume rebuilds from CLI args + disk settings" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="405" width="500" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="l7" value="⑦ Hook-based Interception&#xa;PreToolUse hooks — can deny/ask/modify; PermissionRequest hooks — async resolution" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="100" y="470" width="500" height="50" as="geometry"/>
        </mxCell>
        <!-- Key insight -->
        <mxCell id="insight" value="Key Insight: Defense-in-depth assumes layer independence.&#xa;But layers share performance constraints:&#xa;• >50 subcommands → per-subcommand checks skipped (UI freeze)&#xa;• Auto-mode classifier = separate LLM call with token cost&#xa;• Pre-trust initialization ordering: hooks/MCP execute before trust dialog&#xa;&#xa;93% approval rate → approval fatigue → safety must work independently&#xa;of human vigilance → sandboxing reduced prompts by 84%" style="shape=note;whiteSpace=wrap;html=1;fillColor=#E8EAF6;strokeColor=#3F51B5;fontSize=10;align=left;spacingLeft=8;" vertex="1" parent="1">
          <mxGeometry x="680" y="120" width="400" height="160" as="geometry"/>
        </mxCell>
        <!-- Permission modes gradient -->
        <mxCell id="gradient" value="Permission Mode Gradient (monotonically decreasing safety)&#xa;&#xa;plan ──→ default ──→ acceptEdits ──→ auto ──→ dontAsk ──→ bypassPermissions&#xa;(max safety)                                                                              (max autonomy)&#xa;&#xa;User approves all    Standard         Auto-approve     ML classifier     No prompting    Skips most prompts&#xa;plans first          interactive      file edits       evaluates         deny rules      but safety-critical&#xa;                                                                          still enforced  checks remain" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#E65100;fontSize=10;align=left;spacingLeft=8;fontFamily=monospace;" vertex="1" parent="1">
          <mxGeometry x="680" y="330" width="450" height="160" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
