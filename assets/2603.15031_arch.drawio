          <mxGeometry x="240" y="380" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="s_add2" value="+  (residual, weight=1)" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="s_grp">
