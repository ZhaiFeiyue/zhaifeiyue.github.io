  <diagram id="page2" name="2. AttnRes Math Flow">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="m_v" value="Stack V = [v_0, v_1, …, v_{ℓ-1}, partial]
[N+1, B, T, D]" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="80" width="360" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="m_norm" value="K = RMSNorm(V)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="90" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="m_proj" value="Pseudo-query w_ℓ ∈ R^d
(zero-init for safe start =
uniform averaging)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="460" y="200" width="280" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="m_logits" value="logits = w_ℓᵀ · K
[N+1, B, T]" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="760" y="90" width="240" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="m_smax" value="α = softmax(logits, dim=depth)
→ [N+1, B, T] non-neg, sums to 1" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="90" width="320" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="m_sum" value="h = Σ_i α_{i→ℓ} · v_i
[B, T, D]" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1040" y="200" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="m_eq" value="Full-AttnRes (exact):
  h_ℓ = Σ_{i=0}^{ℓ-1} α_{i→ℓ} · v_i
  α_{i→ℓ} = exp(w_ℓᵀ RMSNorm(k_i)) / Σ_j exp(...)

Block-AttnRes (efficient):
  applied at BLOCK boundaries (every block_size//2 layers)
  + standard &#x27;+&#x27; inside a block

Two-phase merge across blocks:
  h_ℓ = (e^{m1-m}·o1 + e^{m2-m}·o2) / (e^{m1-m}·ℓ1 + e^{m2-m}·ℓ2)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="460" y="350" width="900" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="m_params" value="New trainable params per layer:
  • attn_res_proj  (Linear d→1, used as w_ℓ)
  • mlp_res_proj   (Linear d→1, used as w&#x27;_ℓ)
  • attn_res_norm  (RMSNorm)
  • mlp_res_norm   (RMSNorm)
Total extra ≈ 2L·d  (negligible vs FFN)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="380" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="t_t2" value="Attention Residuals — Mathematical Flow + Block Merge" style="text;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="me1" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="m_v" target="m_norm" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me2" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="m_norm" target="m_logits" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me3" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="m_proj" target="m_logits" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me3_lbl" value="w_ℓ" style="edgeLabel;fontSize=9;fontColor=#333333;" vertex="1" connectable="0" parent="me3">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="me4" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="m_logits" target="m_smax" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me5" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="m_smax" target="m_sum" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me5_lbl" value="α" style="edgeLabel;fontSize=9;fontColor=#333333;" vertex="1" connectable="0" parent="me5">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="me6" style="edgeStyle=orthogonalEdgeStyle;dashed=1;" edge="1" source="m_v" target="m_sum" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="me6_lbl" value="v_i" style="edgeLabel;fontSize=9;fontColor=#333333;" vertex="1" connectable="0" parent="me6">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
  <diagram id="page3" name="3. Dynamics &amp; Scaling">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1500" pageHeight="800" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="d_d1" value="Output norm vs depth
(toy 16-layer)
● Standard: monotonic growth
● AttnRes: BOUNDED &amp; PERIODIC
  (resets at block boundaries)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="380" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="d_d2" value="Gradient norm vs depth
● Standard: dilutes deep → shallow
● AttnRes: more uniform
  → better signal to early layers" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="460" y="60" width="380" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="d_d3" value="Scaling law (paper Fig.):
  baseline ≈ 1.891 · C^{-0.057}
  Block AttnRes matches baseline at
  ~1.25× LESS compute" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="880" y="60" width="380" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="d_t" value="Validation loss (16-L toy):
  baseline    : 1.766
  DenseFormer : 1.767  (no help)
  Full AttnRes: 1.737  (-0.029)
  Block AttnRes: ~1.74" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="40" y="280" width="380" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="d_t2" value="Ablations (paper):
  • softmax &gt; sigmoid
  • single-head depth-attn &gt; multi-head
  • RMSNorm on V is necessary
  • zero-init pseudo-query important
   (start uniform, learn from there)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="460" y="280" width="380" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="d_kimi" value="Production validation:
Kimi-Linear 48B-A3B + AttnRes
  • 1.4 T tokens, Muon + WSD
  • +7.5 GPQA (vs no AttnRes)
  • &lt;4% training overhead
  • I/O per layer ~5.5d (vs 3d standard)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="880" y="280" width="380" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="t_t3" value="Attention Residuals — Empirical Dynamics, Ablations, Production" style="text;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1300" height="30" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
