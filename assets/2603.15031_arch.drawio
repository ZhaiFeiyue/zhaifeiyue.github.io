        <mxCell id="s_out" value="h_ℓ" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="s_grp">
          <mxGeometry x="280" y="530" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="s_note" value="Depth aggregation = uniform sum:
  h_ℓ = h_{ℓ-1} + f_{ℓ-1}(h_{ℓ-1})
Magnitudes drift / blow up
Gradients dilute over depth" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="s_grp">
          <mxGeometry x="100" y="600" width="500" height="110" as="geometry"/>
        </mxCell>
        <mxCell id="a_grp" value="AttnRes Block (Block-AttnRes variant)" style="swimlane;startSize=24;fillColor=#f5f5f5;strokeColor=#b85450;fontStyle=1;fontSize=12;rounded=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="60" width="860" height="760" as="geometry"/>
        </mxCell>
        <mxCell id="a_blocks" value="blocks list (cached):
[h_emb, blk_1, blk_2, …, blk_{n-1}]
+ partial_block (in progress)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="a_grp">
          <mxGeometry x="100" y="50" width="320" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="a_attnres1" value="block_attn_res(
  blocks, partial,
  attn_res_proj, attn_res_norm)
→ softmax over depth" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="a_grp">
          <mxGeometry x="480" y="50" width="340" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="a_n1" value="attn_norm" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="a_grp">
          <mxGeometry x="580" y="170" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_attn" value="Self-Attention" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="a_grp">
          <mxGeometry x="540" y="230" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_add1" value="partial += attn_out" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="a_grp">
          <mxGeometry x="540" y="310" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_attnres2" value="block_attn_res(
  blocks, partial,
  mlp_res_proj, mlp_res_norm)
→ softmax over depth (2nd)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="a_grp">
          <mxGeometry x="480" y="380" width="340" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="a_n2" value="mlp_norm" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="a_grp">
          <mxGeometry x="580" y="510" width="140" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_mlp" value="FFN (SwiGLU)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="a_grp">
          <mxGeometry x="540" y="570" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="a_add2" value="partial += mlp_out" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="a_grp">
          <mxGeometry x="540" y="650" width="240" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="a_note" value="If layer_number % (block_size/2) == 0:
  blocks.append(partial); partial = None
→ start a new BLOCK
Depth aggregation:
  h_ℓ = Σ_i α_{i→ℓ} · v_i  (softmax over depth)
Intra-block: standard &#x27;+&#x27;" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="a_grp">
          <mxGeometry x="80" y="695" width="700" height="60" as="geometry"/>
        </mxCell>
