        <mxCell id="kde_a" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="kda_n" target="kda_a" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="kde_cq" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="kda_q" target="kda_cq" parent="1">
