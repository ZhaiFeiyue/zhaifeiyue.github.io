        </mxCell>
        <mxCell id="kda_q" value="q_proj
Lin(2304 → 32·128)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="180" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kda_k" value="k_proj
Lin(2304 → 32·128)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="480" y="180" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kda_v" value="v_proj
Lin(2304 → 32·128)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="740" y="180" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kda_b" value="β_proj
Lin(2304 → 32) → σ(·)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="1000" y="180" width="220" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kda_a" value="α path (low-rank):
• α_proj_a Lin(2304 → r)
• α_proj_b Lin(r → 32)
→ fused_kda_gate:
  g = -exp(A_log) · softplus(α + dt_bias)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1260" y="180" width="380" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="kda_cq" value="ShortConv1D k=4 + Swish
(causal)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="280" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kda_ck" value="ShortConv1D k=4 + Swish
(causal)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="480" y="280" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kda_cv" value="ShortConv1D k=4 + Swish
(causal)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="740" y="280" width="220" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kda_norm_qk" value="L2 normalize Q, K
(per head, per channel)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="360" width="360" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kda_core" value="KDA Recurrence (per token t):
  S_t = (I − β_t · k_t k_tᵀ) · Diag(α_t) · S_{t-1}
        + β_t · k_t v_tᵀ
  o_t = S_tᵀ · q_t

State size per head: d_k × d_v = 128 × 128
Constrained DPLR form (a=b=k) → ~2× faster
  than generic DPLR chunkwise kernel

Kernels (vLLM):
  • prefill → chunk_kda  (Triton, chunk=64)
  • decode  → fused_recurrent_kda" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="440" width="1100" height="290" as="geometry"/>
        </mxCell>
        <mxCell id="kda_norm_o" value="FusedRMSNormGated
(σ(gate) · RMSNorm(o))
• output gate = sigmoid (not Swish)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="600" y="760" width="380" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="kda_op" value="o_proj
Lin(32·128 → 2304)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="600" y="850" width="380" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kda_res" value="Residual Add" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="930" width="280" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="kda_state_note" value="Cache (per layer):
• recurrent state S: 32·128·128 = 524 288 floats
• short conv state: 3 timesteps × proj_size  (q, k, v each)
→ FIXED size, independent of seq_len
  ⇒ this is the source of KV memory savings" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1340" y="350" width="320" height="280" as="geometry"/>
        </mxCell>
        <mxCell id="t_t2" value="KDA Block — Linear-attention layer with channel-wise gates + delta rule" style="text;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="kde_in" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="kda_in" target="kda_n" parent="1">
          <mxGeometry relative="1" as="geometry"/>
