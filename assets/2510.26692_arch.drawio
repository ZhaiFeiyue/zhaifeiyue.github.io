  <diagram id="page1" name="1. Layer Interleaving (KDA + MLA)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="kl_in" value="Embedding
vocab=163 840 · d=2304" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kl_pat" value="Layer Pattern (27 total):
KDA, KDA, KDA, MLA, KDA, KDA, KDA, MLA,
KDA, KDA, KDA, MLA, KDA, KDA, KDA, MLA,
KDA, KDA, KDA, MLA, KDA, KDA, KDA, MLA,
KDA, KDA, MLA
→ 20 KDA + 7 MLA   (≈ 2.86:1, paper says 3:1)" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="60" width="580" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="kl_legend" value="● KDA   = Kimi Delta Attention (linear, fixed-size state)
● MLA  = Multi-head Latent Attention (full attention, NoPE)

KV cache footprint:
  KDA layer: O(d_k · d_v) per head, fixed
  MLA layer: O(T · 512+64) per token (latent KV)
  → mostly KDA → ~75% KV reduction vs full MLA stack" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1000" y="60" width="660" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="kl_dec" value="Each layer:
  RMSNorm → (KDA | MLA) → +Res
  RMSNorm → MoE FFN     → +Res

MoE: 256 routed + 1 shared, top-8
moe_intermediate=1024, dense=9216
Layer 0 dense (first_k_dense_replace=1)" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="290" width="580" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="kl_lmh" value="RMSNorm + LM Head
Lin(2304 → 163 840)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="380" y="540" width="580" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="kl_out" value="Logits" style="rounded=1;whiteSpace=wrap;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="380" y="630" width="580" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="kl_ctx" value="Context support: 1 048 576 (1M)
NoPE on MLA + recency via KDA gates
→ no RoPE extrapolation issues" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="1000" y="290" width="660" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="t_t1" value="Kimi Linear — Hybrid 20 KDA + 7 MLA layers (released 48B-A3B-Instruct)" style="text;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
