  <diagram id="page3" name="3. MLA Block (NoPE)">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1700" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="mla_in" value="Hidden  [B, T, 2304]" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="700" y="40" width="280" height="50" as="geometry"/>
        </mxCell>
        <mxCell id="mla_n" value="RMSNorm" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="700" y="110" width="280" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="mla_q" value="q_proj
Lin(2304 → 32 · (128+64))
=6 144  (no q_lora_rank)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="180" width="280" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="mla_kva" value="kv_a_proj
Lin(2304 → 512 + 64)
(latent kv + RoPE k)
+ RMSNorm(latent)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="180" width="280" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="mla_kvb" value="kv_b_proj
Lin(512 → 32·(128+128))
=8 192" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="540" y="300" width="280" height="70" as="geometry"/>
        </mxCell>
        <mxCell id="mla_qsplit" value="Q split:
Q_nope [32,128] + Q_rope [32,64]
— but mla_use_nope=True → drop RoPE!
→ in NoPE mode Q_rope is unused" style="rounded=1;whiteSpace=wrap;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="290" width="300" height="80" as="geometry"/>
        </mxCell>
        <mxCell id="mla_attn" value="MLA Attention (NoPE)
32 heads · head_dim=192 effective
NO position bias
  → recency must come from
  data-dependent gating in KDA layers" style="rounded=1;whiteSpace=wrap;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="220" y="410" width="600" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="mla_op" value="o_proj
Lin(32·128 → 2304)" style="rounded=1;whiteSpace=wrap;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="220" y="560" width="280" height="60" as="geometry"/>
        </mxCell>
        <mxCell id="mla_res" value="Residual Add" style="rounded=1;whiteSpace=wrap;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=10;" vertex="1" parent="1">
          <mxGeometry x="280" y="640" width="220" height="35" as="geometry"/>
        </mxCell>
        <mxCell id="mla_kv_note" value="MLA KV cache:
  per token: 512 (latent) + 64 (rope k)  = 576 floats
  vs standard MHA: 32·128·2 = 8 192
  → 14× reduction even in MLA layers
  → KDA layers have NO per-token cache
     → overall ~75% KV reduction" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="880" y="180" width="720" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="mla_nope_note" value="NoPE rationale:
  RoPE forces a fixed positional decay that doesn&#x27;t extrapolate
  cleanly past training context. Combined with KDA layers&#x27;
  data-dependent recency, NoPE on MLA layers gives:
   • cleaner long-context behaviour (paper Table 5)
   • simpler kernels (no RoPE rotation in attention)
   • model_max_length = 1 048 576 (1M)" style="rounded=0;whiteSpace=wrap;fillColor=#fafafa;strokeColor=#bbbbbb;fontSize=10;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="880" y="410" width="720" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="t_t3" value="MLA Block (NoPE) — used in 7 of 27 layers" style="text;fontSize=16;fontStyle=1;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1300" height="30" as="geometry"/>
        </mxCell>
        <mxCell id="mle_in" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_in" target="mla_n" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_q" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_n" target="mla_q" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_kva" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_n" target="mla_kva" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_kvb" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_kva" target="mla_kvb" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_qs" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_q" target="mla_qsplit" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_qa" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_qsplit" target="mla_attn" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_qa_lbl" value="Q_nope only" style="edgeLabel;fontSize=9;fontColor=#333333;" vertex="1" connectable="0" parent="mle_qa">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="mle_ka" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_kvb" target="mla_attn" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_ka_lbl" value="K_nope+V" style="edgeLabel;fontSize=9;fontColor=#333333;" vertex="1" connectable="0" parent="mle_ka">
          <mxGeometry x="-0.2" relative="1" as="geometry"><mxPoint as="offset"/></mxGeometry>
        </mxCell>
        <mxCell id="mle_oa" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_attn" target="mla_op" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="mle_res" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="mla_op" target="mla_res" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
      </root>
